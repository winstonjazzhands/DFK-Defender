import { createClient, type SupabaseClient } from 'jsr:@supabase/supabase-js@2';

const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type, x-session-token, cache-control',
  'Access-Control-Allow-Methods': 'POST, OPTIONS',
};


Deno.serve(async (req) => {
  if (req.method === 'OPTIONS') return new Response('ok', { status: 200, headers: corsHeaders });

  try {
    const authHeader = req.headers.get('Authorization') || '';
    const fallbackHeader = req.headers.get('x-session-token') || '';
    const fallbackToken = String(fallbackHeader).trim();
    const authToken = authHeader.replace(/^Bearer\s+/i, '').trim();
    const token = fallbackToken || authToken;

    console.log('submit-run auth context', {
      hasAuthorization: Boolean(authHeader),
      hasSessionToken: Boolean(fallbackHeader),
      authLooksLikePublishableKey: /^sb_(publishable|anon)_/i.test(authToken),
    });

    if (!token || /^sb_(publishable|anon)_/i.test(token)) {
      return json({ error: 'Valid session token required.', code: 'missing_session_token' }, 401);
    }

    const admin = createAdmin();
    const { data: session, error: sessionError } = await admin
      .from('wallet_sessions')
      .select('session_token, wallet_address, expires_at, revoked_at')
      .eq('session_token', token)
      .maybeSingle();

    if (sessionError) {
      console.error('submit-run wallet session lookup failed', normalizeError(sessionError));
      return json({ error: 'Session lookup failed.', code: 'session_lookup_failed' }, 500);
    }
    if (!session) return json({ error: 'Session not found.', code: 'session_not_found' }, 401);
    if (session.revoked_at) return json({ error: 'Session revoked.', code: 'session_revoked' }, 401);
    if (Date.now() >= new Date(session.expires_at).getTime()) return json({ error: 'Session expired.', code: 'session_expired' }, 401);

    const body = await req.json().catch((error) => {
      console.error('submit-run invalid json body', normalizeError(error));
      return null;
    });
    if (!body || typeof body !== 'object') return json({ error: 'Invalid request body.', code: 'invalid_body' }, 400);

    console.log('submit-run body summary', {
      keys: Object.keys(body as Record<string, unknown>).sort(),
      walletAddress: (body as Record<string, unknown>).walletAddress ?? null,
      clientRunId: (body as Record<string, unknown>).clientRunId ?? null,
    });

    const walletAddress = normalizeAddress((body as Record<string, unknown>).walletAddress as string);
    if (!walletAddress) return json({ error: 'walletAddress is required.', code: 'wallet_required' }, 400);
    if (walletAddress !== session.wallet_address) return json({ error: 'Wallet mismatch.', code: 'wallet_mismatch' }, 401);

    const clientRunId = String((body as Record<string, unknown>).clientRunId || '').trim();
    if (!clientRunId) return json({ error: 'clientRunId is required.', code: 'client_run_id_required' }, 400);

    const requestedDisplayName = typeof (body as Record<string, unknown>).displayName === 'string' && String((body as Record<string, unknown>).displayName).trim()
      ? String((body as Record<string, unknown>).displayName).trim().slice(0, 64)
      : null;
    const waveReached = sanitizeInt((body as Record<string, unknown>).waveReached);
    const wavesCleared = sanitizeInt((body as Record<string, unknown>).wavesCleared);
    const portalHpLeft = sanitizeInt((body as Record<string, unknown>).portalHpLeft);
    const goldOnHand = sanitizeInt((body as Record<string, unknown>).goldOnHand);
    const premiumJewels = sanitizeInt((body as Record<string, unknown>).premiumJewels);
    const gameVersion = String((body as Record<string, unknown>).gameVersion || 'unknown').slice(0, 80);
    const mode = String((body as Record<string, unknown>).mode || 'easy').slice(0, 30);
    const result = String((body as Record<string, unknown>).result || 'loss').slice(0, 30);
    const heroes = Array.isArray((body as Record<string, unknown>).heroes) ? (body as Record<string, unknown>).heroes as unknown[] : [];
    const stats = (body as Record<string, unknown>).stats && typeof (body as Record<string, unknown>).stats === 'object'
      ? (body as Record<string, unknown>).stats as Record<string, unknown>
      : {};
    const usedWalletHeroes = Boolean(stats.usedWalletHeroes || heroes.some((hero) => {
      const row = hero as Record<string, unknown>;
      return Boolean(row.usedWalletHero || Number(row.walletHeroCount || 0) > 0);
    }));
    const completedAt = safeIsoDate((body as Record<string, unknown>).completedAt) || new Date().toISOString();
    const runStartedAt = safeIsoDate((body as Record<string, unknown>).runStartedAt);

    const existingPlayer = await fetchExistingPlayer(admin, walletAddress);
    const resolvedDisplayName = cleanName(existingPlayer?.vanity_name) || cleanName(existingPlayer?.display_name) || requestedDisplayName || null;

    // Ensure the player row exists and is current before inserting the run. This avoids
    // foreign-key failures if the player row was not created yet or drifted from the session flow.
    await upsertPlayer(admin, {
      wallet_address: walletAddress,
      display_name: resolvedDisplayName,
      best_wave: Math.max(waveReached, Number(existingPlayer?.best_wave || 0)),
      total_runs: Number(existingPlayer?.total_runs || 0) + 1,
      total_waves_cleared: Number(existingPlayer?.total_waves_cleared || 0) + wavesCleared,
      last_run_at: completedAt,
      used_wallet_heroes: Boolean(existingPlayer?.used_wallet_heroes) || usedWalletHeroes,
    });

    try {
      await insertRun(admin, {
        wallet_address: walletAddress,
        client_run_id: clientRunId,
        display_name_snapshot: resolvedDisplayName,
        game_version: gameVersion,
        mode,
        result,
        wave_reached: waveReached,
        waves_cleared: wavesCleared,
        portal_hp_left: portalHpLeft,
        gold_on_hand: goldOnHand,
        premium_jewels: premiumJewels,
        heroes_json: heroes,
        stats_json: stats,
        run_started_at: runStartedAt,
        completed_at: completedAt,
      });
    } catch (error) {
      if (error instanceof DuplicateRunError) return json({ ok: true, duplicate: true }, 200);
      throw error;
    }

    const { error: touchError } = await admin
      .from('wallet_sessions')
      .update({ last_seen_at: new Date().toISOString() })
      .eq('session_token', token);
    if (touchError) {
      console.error('submit-run wallet session touch failed', normalizeError(touchError));
    }

    return json({ ok: true }, 200);
  } catch (error) {
    const details = normalizeError(error);
    console.error('submit-run fatal error', details);
    return json({
      error: details.message || 'Run submission failed.',
      code: details.code,
      details: details.details,
      hint: details.hint,
      name: details.name,
    }, 500);
  }
});

async function fetchExistingPlayer(admin: SupabaseClient, walletAddress: string) {
  const selectVariants = [
    'display_name, vanity_name, best_wave, total_runs, total_waves_cleared, used_wallet_heroes',
    'display_name, vanity_name, best_wave, total_runs, total_waves_cleared',
  ];

  for (const columns of selectVariants) {
    const { data, error } = await admin.from('players').select(columns).eq('wallet_address', walletAddress).maybeSingle();
    if (!error) return data as Record<string, unknown> | null;
    if (!isMissingColumnError(error)) {
      console.error('submit-run existing player lookup failed', { columns, ...normalizeError(error) });
      throw error;
    }
    console.warn('submit-run existing player lookup retrying without missing column', { columns, ...normalizeError(error) });
  }

  return null;
}

async function insertRun(admin: SupabaseClient, payload: Record<string, unknown>) {
  const payloadVariants = [
    payload,
    omitKeys(payload, ['premium_jewels', 'run_started_at']),
    omitKeys(payload, ['premium_jewels', 'run_started_at', 'display_name_snapshot']),
    omitKeys(payload, ['premium_jewels', 'run_started_at', 'display_name_snapshot', 'heroes_json', 'stats_json']),
  ];

  let lastError: unknown = null;
  for (const variant of payloadVariants) {
    const { error } = await admin.from('runs').insert(variant);
    if (!error) return;
    const message = String(error.message || '').toLowerCase();
    if (message.includes('duplicate key')) {
      throw new DuplicateRunError();
    }
    lastError = error;
    console.error('submit-run run insert failed', { payloadKeys: Object.keys(variant), ...normalizeError(error) });
    if (message.includes('violates foreign key constraint')) {
      throw new Error(`runs insert foreign key failure: ${error.message}`);
    }
    if (!isMissingColumnError(error)) throw error;
  }

  throw lastError;
}

async function upsertPlayer(admin: SupabaseClient, payload: Record<string, unknown>) {
  const payloadVariants = [
    payload,
    omitKeys(payload, ['used_wallet_heroes']),
  ];

  let lastError: unknown = null;
  for (const variant of payloadVariants) {
    const { error } = await admin.from('players').upsert(variant, { onConflict: 'wallet_address' });
    if (!error) return;
    lastError = error;
    console.error('submit-run player upsert failed', { payloadKeys: Object.keys(variant), ...normalizeError(error) });
    if (!isMissingColumnError(error)) throw error;
  }

  throw lastError;
}

class DuplicateRunError extends Error {
  constructor() {
    super('Duplicate run.');
    this.name = 'DuplicateRunError';
  }
}

function omitKeys(payload: Record<string, unknown>, keys: string[]) {
  const copy = { ...payload };
  for (const key of keys) delete copy[key];
  return copy;
}

function isMissingColumnError(error: unknown) {
  const message = String((error && typeof error === 'object' && 'message' in error ? (error as { message?: unknown }).message : '') || '').toLowerCase();
  return message.includes('column') && (message.includes('does not exist') || message.includes('not found in schema cache'));
}

function normalizeError(error: unknown) {
  if (error instanceof DuplicateRunError) {
    return { message: error.message, code: 'duplicate_run', details: null, hint: null, name: error.name };
  }
  if (error && typeof error === 'object') {
    const row = error as Record<string, unknown>;
    return {
      message: String(row.message || 'Run submission failed.'),
      code: row.code ?? null,
      details: row.details ?? null,
      hint: row.hint ?? null,
      name: row.name ?? null,
    };
  }
  return { message: String(error || 'Run submission failed.'), code: null, details: null, hint: null, name: null };
}

function safeIsoDate(value: unknown) {
  if (!value) return null;
  const date = new Date(String(value));
  return Number.isNaN(date.getTime()) ? null : date.toISOString();
}

function sanitizeInt(value: unknown) {
  const parsed = Number(value || 0);
  if (!Number.isFinite(parsed) || parsed < 0) return 0;
  return Math.round(parsed);
}

function createAdmin() {
  return createClient(
    Deno.env.get('SUPABASE_URL')!,
    Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!,
    { auth: { persistSession: false, autoRefreshToken: false } },
  );
}

function json(payload: unknown, status = 200) {
  return new Response(JSON.stringify(payload), { status, headers: { ...corsHeaders, 'Content-Type': 'application/json' } });
}
