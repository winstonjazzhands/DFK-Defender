  function getSpawnBounds() {
    const spawns = game.grid.filter(t => t.type === 'spawn');
    const xs = spawns.map(t => t.x);
    const ys = spawns.map(t => t.y);
    return {
      minX: Math.min(...xs),
      minY: Math.min(...ys),
      maxX: Math.max(...xs),
      maxY: Math.max(...ys),
    };
  }

