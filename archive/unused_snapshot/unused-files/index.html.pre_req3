<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portal Siege TD</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <div id="app">
    <main class="main-layout">
      <section class="left-panel panel">
        <h2>Run Log</h2>
        <div id="log" class="log"></div>
        <button id="speedToggleBtn" class="speed-toggle" type="button" aria-pressed="false">▶ 2× Speed</button>
        <button id="mobileModeBtn" class="mobile-toggle" type="button" aria-pressed="false">📱 Mobile Mode</button>
      </section>

      <section class="center-panel panel">
        <div id="banner" class="banner hidden"></div>
        <div id="grid" class="grid" aria-label="battlefield"></div>
      </section>

      <section class="right-panel panel">
        <h2>Selected</h2>
        <div id="selectedInfo" class="selected-info">Nothing selected.</div>
        <div class="action-group">
          <button id="upgradeBtn" disabled>Upgrade</button>
          <button id="moveBtn" disabled>Move</button>
          <button id="rebuildBarriersBtn" class="secondary" disabled>Rebuild Barriers</button>
        </div>
        <div id="abilitiesPanel" class="abilities-panel"></div>
      </section>
    </main>

    <footer class="bottom-panel panel">
      <div class="controls-row action-row">
        <button id="startWaveBtn" class="small-action" disabled>Start Next Wave</button>
        <button id="skipSetupBtn" class="secondary small-action hidden">Auto-Place Warrior</button>
        <button id="restartBtn" class="small-action">New Run</button>
        <div class="topbar footer-topbar">
          <div><strong>Portal HP:</strong> <span id="portalHp">--</span></div>
          <div><strong>JEWEL:</strong> <span id="jewelCount">0</span></div>
          <div><strong>Wave:</strong> <span id="waveCount">0</span></div>
          <div><strong>Pattern:</strong> <span id="patternLabel">--</span></div>
          <div><strong>Mutation:</strong> <span id="mutationLabel">None</span></div>
          <div><strong>Next Wave:</strong> <span id="countdownLabel">--</span></div>
        </div>
      </div>
      <div class="footer-info panel-lite">
        <div id="phaseLabel" class="phase-label">Loading…</div>
        <p id="instructionText" class="instruction"></p>
      </div>
      <div class="controls-stack">
        <div class="control-section hire-section">
          <div id="hirePanel" class="card-list hire-list"></div>
        </div>
        <div class="control-section relic-section">
          <h3>Relic Shop</h3>
          <div id="relicPanel" class="card-list relic-list"></div>
        </div>
      </div>
    </footer>
  </div>

  <script src="js/app.js"></script>
</body>
</html>
