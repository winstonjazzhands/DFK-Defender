      .filter((run) => (Number(run.bestWave || 0) || 0) > 0)
      .sort((a, b) => {
        const waveDiff = (Number(b.bestWave || 0) || 0) - (Number(a.bestWave || 0) || 0);
        if (waveDiff) return waveDiff;
        return (Number(a.runNumber || 0) || 0) - (Number(b.runNumber || 0) || 0);
