  function countValidPortalPlacements() {
    let count = 0;
    for (let y = 0; y < HEIGHT - 1; y += 1) {
      for (let x = 0; x < WIDTH - 1; x += 1) {
        if (canPlacePortal(x, y)) count += 1;
