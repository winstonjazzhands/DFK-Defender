      if (!window.localStorage) return;
      const uniqueIds = Array.from(new Set((Array.isArray(ids) ? ids : []).map(id => String(id || '').trim()).filter(Boolean)));
      window.localStorage.setItem(getKnownRelicStorageKey(), JSON.stringify(uniqueIds));
    } catch (error) {}
  }

