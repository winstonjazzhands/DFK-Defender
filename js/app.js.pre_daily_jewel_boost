    const burnCost = Number(MILESTONE_HERO_OFFER_COSTS[safeWave] || (safeWave >= 100 ? safeWave * 5000 : safeWave * 4000));
    return { wave: safeWave, burnCost, heroLevel: safeWave };
  }

