    const byTile = new Map();
    for (const e of game.enemies) {
      const k = `${e.x},${e.y}`;
      if (!byTile.has(k)) byTile.set(k, []);
      byTile.get(k).push(e);
    }
    const enemiesHere = byTile.get(`${enemy.x},${enemy.y}`) || [enemy];
    const offset = getEnemyStackOffset(enemy, enemiesHere);
