    const bossCount = Math.max(1, Math.round(getWaveBossOverrideCount(waveNumber, waveNumber >= 30 ? 2 : 1) * 0.8 * (waveNumber >= 15 ? 0.95 : 1) * getPostWave100EnemyCountMultiplier(waveNumber)));
