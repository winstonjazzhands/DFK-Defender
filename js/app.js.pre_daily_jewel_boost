  function scheduleAbilityInfoHide(delay = 120) {
    if (game.infoPopupHideTimer) clearTimeout(game.infoPopupHideTimer);
    game.infoPopupHideTimer = setTimeout(() => {
      if (!game.infoPopupPinned && !game.infoPopupHover) hideAbilityInfo();
