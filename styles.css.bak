}


/* v15 precise mobile bottom bar + message fixes */
@media (max-width: 1024px) and (orientation: landscape) {
  #mobileBottomBar.mobile-bottom-bar {
    position: fixed !important;
    left: calc(var(--mobile-safe-left) + var(--mobile-rail-w) + 10px) !important;
