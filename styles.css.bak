    height: var(--board-height) !important;
    min-height: var(--board-height) !important;
    max-height: var(--board-height) !important;
    margin: 0 !important;
    justify-self: start !important;
    align-self: start !important;
    place-self: start !important;
    grid-template-columns: repeat(14, var(--tile-size)) !important;
    grid-template-rows: repeat(6, var(--tile-size)) !important;
    gap: var(--tile-gap) !important;
  }

  .tile,
  .grid > .tile {
    width: var(--tile-size) !important;
    height: var(--tile-size) !important;
  }

  #mobileBottomBar {
    left: var(--mobile-board-left) !important;
    right: var(--mobile-board-right) !important;
    bottom: var(--mobile-bottom-offset) !important;
  }

  .status-overlay {
    left: var(--mobile-board-left) !important;
    right: var(--mobile-board-right) !important;
    bottom: calc(var(--mobile-bottom-offset) + var(--mobile-bottom-reserve) + 8px) !important;
    width: auto !important;
    max-width: none !important;
  }

  body.intro-open .intro-modal,
  body.intro-open .intro-modal-card {
    z-index: 5000 !important;
  }
}


/* v10: final mobile landscape fit + overlay message cleanup */
.tile,
