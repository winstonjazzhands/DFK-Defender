:root {
  --board-padding-buffer: 24px;
  --bg: #0f1520;
  --tile-size: 84px;
  --tile-gap: 6px;
  --panel: #1a2333;
  --panel-2: #202c41;
  --tile: #7c6630;
  --tile-border: #a4833f;
  --text: #e8eefc;
  --muted: #a9b6d3;
  --danger: #ff7b7b;
  --gold: #e6c15d;
  --green: #7be28c;
  --portal: #76a5ff;
  --obstacle: #8a7446;
  --random-obstacle: #8e7b53;
  --spawn: #8b4b2d;
}

* { box-sizing: border-box; }
html, body {
  min-height: 100dvh;
}

body {
  margin: 0;
  font-family: Inter, Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  overflow-y: auto;
  padding-left: env(safe-area-inset-left);
  padding-right: env(safe-area-inset-right);
  position: relative;
}
body::before {
  content: "";
  position: fixed;
  inset: 0;
  background: url(assets/background.png) top center / cover no-repeat;
  pointer-events: none;
  z-index: -1;
}

#app {
  max-width: 1800px;
  margin: 0;
  padding: 10px 12px 12px;
  min-height: 100dvh;
}

.panel {
  background: var(--panel);
  border: 1px solid #2e3d58;
  border-radius: 14px;
  box-shadow: 0 6px 24px rgba(0,0,0,0.25);
}

.topbar {
  display: grid;
  grid-template-columns: repeat(6, minmax(88px, 1fr));
  gap: 4px;
  width: min(760px, 100%);
  max-width: 100%;
  margin: 0;
}

.topbar > div {
  background: var(--panel);
  border: 1px solid #2e3d58;
  border-radius: 10px;
  padding: 5px 8px;
  text-align: center;
  min-width: 84px;
  font-size: 0.78rem;
  line-height: 1.15;
}


.footer-topbar {
  margin-left: 10px;
  flex: 1 1 auto;
  align-self: center;
}
.footer-topbar strong {
  font-size: 0.74rem;
}
.footer-topbar span {
  font-size: 0.84rem;
}

.main-layout {
  display: grid;
  grid-template-columns: 200px 1fr 224px;
  gap: 12px;
  align-items: start;
}

.left-panel, .right-panel, .bottom-panel {
  padding: 10px;
}

.speed-toggle {
  margin-top: 10px;
  width: 100%;
  min-height: 34px;
  border-radius: 10px;
  border: 1px solid #4d5f87;
  background: linear-gradient(180deg, #2e3f63, #24334f);
  color: var(--text);
  font-size: 0.86rem;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.12s ease, background 0.12s ease, border-color 0.12s ease;
}
.speed-toggle:hover { transform: translateY(-1px); border-color: #7893d1; }
.speed-toggle.active {
  background: linear-gradient(180deg, #5d52ff, #4a3fd1);
  border-color: #9aa4ff;
  box-shadow: 0 0 0 1px rgba(154,164,255,0.2), 0 6px 18px rgba(86,77,214,0.28);
}
.speed-toggle:focus-visible { outline: 2px solid #9fb6e6; outline-offset: 2px; }

.mobile-toggle {
  margin-top: 8px;
  width: 100%;
  min-height: 34px;
  border-radius: 10px;
  border: 1px solid #4d5f87;
  background: linear-gradient(180deg, #304a5d, #243948);
  color: var(--text);
  font-size: 0.84rem;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.12s ease, background 0.12s ease, border-color 0.12s ease;
}
.mobile-toggle:hover { transform: translateY(-1px); border-color: #78b4d1; }
.mobile-toggle.active {
  background: linear-gradient(180deg, #2c8f74, #1e6b58);
  border-color: #7be2bf;
  box-shadow: 0 0 0 1px rgba(123,226,191,0.2), 0 6px 18px rgba(30,107,88,0.28);
}
.mobile-toggle:focus-visible { outline: 2px solid #9fe6d1; outline-offset: 2px; }

.right-panel {
  position: relative;
}

.hero-quick-select {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin: 0 0 10px;
}

.hero-quick-btn {
  position: relative;
  flex: 1 1 calc(50% - 6px);
  min-width: 0;
  padding: 6px 8px;
  border-radius: 10px;
  border: 1px solid rgba(110, 142, 220, 0.42);
  background: rgba(22, 31, 58, 0.88);
  color: var(--text);
  font-size: 0.72rem;
  font-weight: 800;
  line-height: 1.1;
}

.hero-quick-btn.has-ready-ability::after {
  content: '';
  position: absolute;
  top: 5px;
  right: 5px;
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: #54df72;
  box-shadow: 0 0 0 1px rgba(12, 22, 18, 0.78), 0 0 5px rgba(84, 223, 114, 0.55);
}

.hero-quick-btn.is-selected {
  border-color: #f3d47d;
  box-shadow: 0 0 0 1px rgba(243, 212, 125, 0.24) inset;
}

.hero-quick-empty {
  width: 100%;
  font-size: 0.76rem;
  color: var(--muted);
}

.center-panel {
  padding: 8px;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.grid {
  position: relative;
  display: grid;
  grid-template-columns: repeat(14, var(--tile-size));
  grid-template-rows: repeat(6, var(--tile-size));
  gap: var(--tile-gap);
  justify-content: flex-start;
  margin: 0 auto;
}

.tile {
  box-sizing: border-box;
  width: var(--tile-size);
  height: var(--tile-size);
  border-radius: 10px;
  border: 1px solid var(--tile-border);
  background:
    radial-gradient(circle at 25% 25%, rgba(255,224,150,0.08), transparent 22%),
    radial-gradient(circle at 70% 68%, rgba(77,55,18,0.10), transparent 24%),
    linear-gradient(180deg, #8f7436 0%, #7a652f 55%, #6e5c2d 100%);
  position: relative;
  cursor: pointer;
  overflow: visible;
  user-select: none;
  box-shadow: inset 0 1px 0 rgba(255,233,173,0.08), inset 0 -3px 6px rgba(61,45,14,0.16);
}

.tile:hover { outline: 2px solid #9fb6e6; }
.tile * { pointer-events: none; }

.tile.spawn { background: none !important; }
.tile.portal { background: var(--tile); }
.tile.random-obstacle {
  background: none;
}
.tile.random-obstacle::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url(assets/rock.png) center/contain no-repeat;
  pointer-events: none;
}
.tile.player-obstacle { background: linear-gradient(180deg, #8f7541, #6f582f); }
.tile.preview-valid { outline: 2px solid var(--green); }
.tile.preview-invalid { outline: 2px solid var(--danger); }
.tile.selected { outline: 3px solid #f8df7f; }
.tile.move-target { outline: 2px solid #7be28c; }
.tile.attacking { box-shadow: inset 0 0 0 2px rgba(255,123,123,0.8); }

.tile.range-tile::before {
  content: "";
  position: absolute;
  inset: 6px;
  border-radius: 8px;
  pointer-events: none;
  opacity: 0.68;
}
.tile.range-warrior::before { background: rgba(79,136,255,0.30); box-shadow: inset 0 0 0 1px rgba(79,136,255,0.42); }
.tile.range-archer::before { background: rgba(62,159,108,0.24); box-shadow: inset 0 0 0 1px rgba(62,159,108,0.38); }
.tile.range-wizard::before { background: rgba(142,101,255,0.24); box-shadow: inset 0 0 0 1px rgba(142,101,255,0.38); }
.tile.range-priest::before { background: rgba(209,219,141,0.28); box-shadow: inset 0 0 0 1px rgba(209,219,141,0.42); }
.tile.range-pirate::before { background: rgba(184,118,36,0.38); box-shadow: inset 0 0 0 1px rgba(227,160,77,0.52); }


.tile.hit-warrior { box-shadow: inset 0 0 0 2px rgba(79,136,255,0.55); }
.tile.hit-archer { box-shadow: inset 0 0 0 2px rgba(62,159,108,0.55); }
.tile.hit-wizard { box-shadow: inset 0 0 0 2px rgba(142,101,255,0.55); }
.tile.hit-priest { box-shadow: inset 0 0 0 2px rgba(209,219,141,0.65); }
.tile.hit-pirate { box-shadow: inset 0 0 0 2px rgba(207,138,55,0.6); }

.hit-flash {
  position: absolute;
  inset: 0;
  border-radius: 10px;
  pointer-events: none;
  animation: hitPulse 0.36s ease-out forwards;
}
.hit-flash-warrior { background: radial-gradient(circle, rgba(79,136,255,0.45) 0%, rgba(79,136,255,0.12) 55%, rgba(79,136,255,0) 100%); }
.hit-flash-archer { background: radial-gradient(circle, rgba(62,159,108,0.45) 0%, rgba(62,159,108,0.12) 55%, rgba(62,159,108,0) 100%); }
.hit-flash-wizard { background: radial-gradient(circle, rgba(142,101,255,0.45) 0%, rgba(142,101,255,0.12) 55%, rgba(142,101,255,0) 100%); }
.hit-flash-priest { background: radial-gradient(circle, rgba(209,219,141,0.55) 0%, rgba(209,219,141,0.15) 55%, rgba(209,219,141,0) 100%); }
.hit-flash-pirate { background: radial-gradient(circle, rgba(207,138,55,0.5) 0%, rgba(207,138,55,0.14) 55%, rgba(207,138,55,0) 100%); }

.hit-text {
  position: absolute;
  top: 26px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 12px;
  font-weight: 800;
  color: #ffffff;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  animation: floatFade 0.45s ease-out forwards;
  z-index: 3;
}

@keyframes hitPulse {
  0% { opacity: 0.95; transform: scale(0.94); }
  100% { opacity: 0; transform: scale(1.08); }
}

@keyframes floatFade {
  0% { opacity: 1; transform: translateX(-50%) translateY(0); }
  100% { opacity: 0; transform: translateX(-50%) translateY(-10px); }
}

.tile-label {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 15px;
  color: #f3f6ff;
}



.tower-chip {
  position: absolute;
  top: 6px;
  left: 6px;
  right: 6px;
  height: 16px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 700;
}
.tower-warrior { background: #4f88ff; }
.tile-hero-warrior { background: linear-gradient(180deg, rgba(79,136,255,0.16), rgba(122,101,47,0.92)) !important; }
.tile-hero-archer { background: linear-gradient(180deg, rgba(62,159,108,0.16), rgba(122,101,47,0.92)) !important; }
.tile-hero-wizard { background: linear-gradient(180deg, rgba(142,101,255,0.16), rgba(122,101,47,0.92)) !important; }
.tile-hero-priest { background: linear-gradient(180deg, rgba(209,219,141,0.18), rgba(122,101,47,0.92)) !important; }
.tile-hero-pirate { background: linear-gradient(180deg, rgba(207,138,55,0.18), rgba(122,101,47,0.92)) !important; }
.tower-archer { background: #3e9f6c; }
.tower-wizard { background: #8e65ff; }
.tower-priest { background: #d1db8d; color: #152039; }
.tower-pirate { background: #cf8a37; }

.hp-bar, .cooldown-bar {
  position: absolute;
  left: 4px;
  right: 4px;
  height: 6px;
  border-radius: 4px;
  background: rgba(255,255,255,0.12);
  overflow: visible;
}
.hp-bar { top: 40px; }
.cooldown-bar { top: 50px; }
.hp-fill { height: 100%; background: #75dd8c; }
.cooldown-fill { height: 100%; background: #69a0ff; }

.enemy-stack {
  position: absolute;
  right: 4px;
  bottom: 32px;
  display: flex;
  gap: 2px;
  flex-wrap: wrap;
  max-width: 32px;
  justify-content: flex-end;
}
.enemy-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.35);
}
.enemy-grunt { background: #df5d5d; }
.enemy-runner { background: #ffad61; }
.enemy-brute { background: #ca4c8a; }
.enemy-boss { background: transparent; width: 12px; height: 16px; border: 0; }
.enemy-packboc { background: transparent; border: 0; border-radius: 0; image-rendering: pixelated; pointer-events: none; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.4)); }
.enemy-slowed { box-shadow: none; }
.enemy-boss.enemy-slowed {
  box-shadow: none;
}
.enemy-slow-snowflake {
  position: absolute;
  pointer-events: none;
  z-index: 9;
  line-height: 1;
  color: #f5fbff;
  text-shadow: 0 0 2px rgba(56, 100, 148, 0.9), 0 0 6px rgba(164, 205, 255, 0.7);
  filter: drop-shadow(0 0 2px rgba(0,0,0,0.55));
}
.enemy-slow-snowflake.boss-slow-snowflake {
  z-index: 10;
}

.phase-label {
  font-weight: 700;
  color: var(--gold);
  margin-bottom: 8px;
  font-size: 75%;
}
.instruction {
  color: var(--muted);
  line-height: 1.4;
  min-height: 44px;
  font-size: 75%;
}
.log {
  max-height: 41px;
  overflow: auto;
  background: var(--panel-2);
  border-radius: 10px;
  padding: 10px;
  font-size: 9.75px;
  line-height: 1.35;
}
.log-entry {
  padding: 4px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.selected-info {
  min-height: 112px;
  background: var(--panel-2);
  border-radius: 10px;
  padding: 10px;
  line-height: 1.35;
  margin-bottom: 8px;
  font-size: 70%;
}
.action-group {
  display: flex;
  gap: 6px;
  margin-bottom: 4px;
}
.right-panel h3 {
  margin: 0;
  display: none;
}
.abilities-panel,
.card-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.card {
  background: var(--panel-2);
  border: 1px solid #314666;
  border-radius: 10px;
  padding: 10px;
}
.card h4 {
  margin: 0 0 6px 0;
  font-size: 14px;
}
.card p {
  margin: 4px 0;
  color: var(--muted);
  font-size: 12px;
}

.bottom-panel {
  width: min(calc(13 * var(--tile-size) + 12 * var(--tile-gap)), 100%);
  max-width: calc(13 * var(--tile-size) + 12 * var(--tile-gap));
  margin: 5px auto 0;
  padding: 8px 10px 10px;
  position: relative;
  z-index: 6;
}
.controls-row {
  display: flex;
  gap: 12px;
  align-items: center;
  flex-wrap: wrap;
}
.action-row {
  gap: 8px;
}
.controls-stack {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 6px;
}
.control-section h3 {
  margin: 0 0 6px;
}
.hire-list {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 8px;
  align-items: stretch;
  min-height: 112px;
}
.hire-list .card {
  min-height: 100%;
}
.hire-section {
  min-height: 112px;
}
.hire-list {
  min-height: 112px;
  align-content: start;
}
.hire-list .card {
  min-height: 112px;
}
.relic-list {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 8px;
  align-items: start;
}

button {
  background: #3a6de0;
  color: white;
  border: none;
  border-radius: 10px;
  padding: 10px 14px;
  cursor: pointer;
  font-weight: 700;
}
.small-action {
  font-size: 0.78rem;
  padding: 7px 10px;
  padding: 7px 10px;
  font-size: 12px;
  border-radius: 8px;
}
button.secondary { background: #49607f; }
button.buy-btn { background: #7e5a18; }
button.warn { background: #b95f37; }
button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.banner {
  position: absolute;
  top: 16px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(18, 26, 41, 0.94);
  border: 1px solid #47679c;
  padding: 10px 14px;
  border-radius: 12px;
  z-index: 20;
  text-align: center;
  min-width: 300px;
}
.hidden { display: none !important; }
.muted { color: var(--muted); }
.good { color: var(--green); }
.bad { color: var(--danger); }
.gold { color: var(--gold); }

@media (max-width: 1280px) {
  .main-layout { grid-template-columns: 1fr; }
  .topbar { grid-template-columns: repeat(3, 1fr); }
}

.footer-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  flex-wrap: wrap;
  width: min(860px, 100%);
  margin: 6px auto 2px;
  padding: 6px 10px;
  min-height: 36px;
}
.panel-lite {
  background: rgba(32,44,65,0.9);
  border: 1px solid #2e3d58;
  border-radius: 12px;
}
.footer-info .phase-label {
  margin: 0;
  font-size: 68%;
}
.footer-info .instruction {
  margin: 0;
  min-height: 0;
  font-size: 68%;
  line-height: 1.25;
  max-width: 700px;
  text-align: center;
}

.ability-row { display: flex; align-items: center; gap: 4px; margin-bottom: 4px; }
.ability-row button { flex: 1; }
.ability-row button.ability-info-icon { flex: 0 0 20px; }
.ability-info-icon { display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; min-width: 20px; border-radius: 999px; background: rgba(255,255,255,0.08); color: var(--gold); font-size: 12px; cursor: help; border: 1px solid rgba(255,255,255,0.12); padding: 0; line-height: 1; aspect-ratio: 1 / 1; }
.locked-skill { opacity: 0.55; filter: grayscale(0.2); }
.relic-pill { display: inline-block; margin: 2px 4px 2px 0; padding: 2px 7px; border-radius: 999px; background: rgba(230,193,93,0.14); border: 1px solid rgba(230,193,93,0.3); color: var(--gold); font-size: 12px; }
.selected-relics { margin-top: 8px; font-size: 12px; color: var(--muted); }
.relic-owned-card { margin-bottom: 8px; }


.ability-banner {
  max-width: 520px;
  line-height: 1.35;
  font-size: 13px;
  color: var(--text);
}

.tile-hover-card {
  display: none !important;
}
.tile-hover-title {
  font-size: 10px;
  font-weight: 800;
  color: #f3f6ff;
  margin-bottom: 2px;
  text-align: center;
}
.tile-hover-skill {
  font-size: 9px;
  line-height: 1.2;
  color: var(--muted);
  white-space: nowrap;
}
.tile-hover-skill.locked {
  opacity: 0.55;
}


.enemy-layer {
  position: absolute;
  inset: 0;
  overflow: visible;
  pointer-events: none;
  z-index: 6;
}

.attack-line-layer {
  position: absolute;
  inset: 0;
  overflow: visible;
}
.attack-line {
  stroke-width: 1;
  stroke-linecap: round;
  opacity: 0.9;
}
.attack-line-warrior { stroke: rgba(96, 170, 255, 0.95); }
.attack-line-archer { stroke: rgba(118, 232, 121, 0.95); }
.attack-line-wizard { stroke: rgba(188, 118, 255, 0.95); }
.attack-line-priest { stroke: rgba(255, 230, 150, 0.95); }
.attack-line-pirate { stroke: rgba(255, 170, 90, 0.95); }
.attack-line-default { stroke: rgba(255,255,255,0.9); }
.enemy-floating {
  position: absolute;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 6px rgba(0,0,0,0.35);
}
.enemy-floating.attacking {
  box-shadow: 0 0 0 2px rgba(255,123,123,0.45), 0 0 8px rgba(0,0,0,0.35);
}
.tile-hover-card {
  pointer-events: auto;
}

.tile:hover .tile-hover-card {
  opacity: 1;
  visibility: visible;
}

.tile-hover-skills {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.tile-hover-skill-btn {
  width: 100%;
  border: 1px solid rgba(126, 155, 215, 0.55);
  background: rgba(31, 45, 68, 0.95);
  color: #eaf0ff;
  border-radius: 8px;
  padding: 3px 5px;
  font-size: 9px;
  line-height: 1.2;
  text-align: left;
  cursor: pointer;
}

.tile-hover-skill-btn:hover:not(:disabled) {
  border-color: rgba(170, 195, 255, 0.95);
  background: rgba(45, 63, 92, 0.98);
}

.tile-hover-skill-btn:disabled,
.tile-hover-skill-btn.locked {
  opacity: 0.55;
  cursor: default;
}


@media (max-width: 1100px) {
  .hire-list, .relic-list {
    grid-template-columns: 1fr;
  }
}

.action-group button {
  padding: 5px 7px;
  font-size: 11px;
  border-radius: 8px;
}
.abilities-panel button {
  padding: 6px 8px;
  font-size: 12px;
}
.left-panel h2 {
  font-size: 22px;
  margin: 0 0 8px;
}
.tile:hover .tile-hover-card {
  display: none !important;
  opacity: 0 !important;
  visibility: hidden !important;
}


.crash-panel {
  position: fixed;
  right: 14px;
  bottom: 14px;
  width: min(420px, calc(100vw - 28px));
  max-height: 62vh;
  overflow: auto;
  z-index: 9999;
  background: #161f31;
  border: 1px solid #51688d;
  border-radius: 12px;
  box-shadow: 0 18px 48px rgba(0,0,0,0.45);
  padding: 10px;
}
.crash-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}
.crash-close {
  min-width: 28px;
  width: 28px;
  height: 28px;
  padding: 0;
  border-radius: 999px;
}
.crash-panel-body {
  font-size: 12px;
  line-height: 1.45;
  color: var(--text);
}
.crash-summary {
  color: #ffd86b;
  margin-bottom: 8px;
}
.crash-state,
.crash-error,
.crash-events {
  background: rgba(255,255,255,0.04);
  border-radius: 8px;
  padding: 8px;
  margin-bottom: 8px;
}
.crash-error {
  color: #ffb2b2;
  white-space: pre-wrap;
  word-break: break-word;
  max-height: 70px;
  overflow: auto;
}
.crash-panel-actions {
  display: flex;
  justify-content: flex-end;
}


.ability-info-popup {
  position: absolute;
  top: 26px;
  left: 14px;
  right: 14px;
  z-index: 30;
  background: rgba(18, 26, 41, 0.98);
  border: 1px solid #47679c;
  border-radius: 12px;
  padding: 10px 12px;
  box-shadow: 0 10px 24px rgba(0,0,0,0.35);
}
.ability-info-popup.hidden {
  display: none !important;
}
.ability-info-popup .ability-banner {
  max-width: none;
  font-size: 12px;
}


.passive-card {
  margin-top: 8px;
  border: 1px solid rgba(230,193,93,0.25);
  background: rgba(255,255,255,0.03);
}
.passive-card h4 {
  margin: 0 0 6px 0;
  font-size: 0.85em;
}
.passive-name {
  font-size: 0.9em;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4px;
}
.passive-subtitle {
  font-size: 12px;
  color: var(--muted);
  margin-bottom: 6px;
}
.passive-card-locked {
  opacity: 0.72;
}

@media (max-width: 1100px) and (orientation: landscape) {
  :root {
  --board-padding-buffer: 24px;
    --tile-size: min(6.35vw, 54px);
    --tile-gap: 3px;
  }
  #app {
    max-width: 100vw;
    padding: 6px;
  }
  .main-layout {
    grid-template-columns: 1fr;
    gap: 8px;
  }
  .center-panel {
    order: 1;
    padding: 6px;
    overflow-x: auto;
  }
  .left-panel {
    order: 2;
  }
  .right-panel {
    order: 3;
  }
  .left-panel, .right-panel, .bottom-panel {
    padding: 8px;
  }
  .topbar {
    grid-template-columns: repeat(3, minmax(74px, 1fr));
    width: 100%;
  }
  .footer-topbar {
    margin-left: 6px;
  }
  .controls-row.action-row {
    flex-wrap: wrap;
    gap: 6px;
  }
  .control-section.hire-section .hire-list,
  .control-section.relic-section .relic-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .log {
    max-height: 90px;
  }
  .selected-info, .abilities-panel {
    font-size: 0.9rem;
  }
}


.pause-toggle {
  margin-top: 8px;
  width: 100%;
  min-height: 34px;
  border-radius: 10px;
  border: 1px solid #6e6c9a;
  background: linear-gradient(180deg, #4a4667, #363252);
  color: var(--text);
  font-size: 0.84rem;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.12s ease, background 0.12s ease, border-color 0.12s ease;
}
.pause-toggle:hover { transform: translateY(-1px); border-color: #a8a5df; }
.pause-toggle.active {
  background: linear-gradient(180deg, #8e65ff, #6248b8);
  border-color: #c3b4ff;
  box-shadow: 0 0 0 1px rgba(195,180,255,0.2), 0 6px 18px rgba(98,72,184,0.28);
}
.portal-art {
  position: absolute;
  z-index: 4;
  pointer-events: none;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 6px 10px rgba(0,0,0,0.35));
}
.portal-art.hidden { display: none; }

.portal-art.portal-art-damaged {
  filter:
    drop-shadow(0 0 6px rgba(255, 85, 85, 0.95))
    drop-shadow(0 0 18px rgba(255, 45, 45, 0.8))
    drop-shadow(0 0 30px rgba(255, 0, 0, 0.55));
  animation: portalDamagePulse 0.6s ease-in-out infinite;
}
@keyframes portalDamagePulse {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.06); opacity: 0.9; }
  100% { transform: scale(1); opacity: 1; }
}


.tile.random-obstacle .tile-label{display:none;}
.tile.player-obstacle .tile-label{font-size:0.72rem; opacity:.92;}

.tile.player-obstacle::after {
  content: "";
  position: absolute;
  inset: 0;
  background: var(--tree-img) center/contain no-repeat;
}

.tile.random-obstacle::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url(assets/rock.png) center/contain no-repeat;
}

.tile.player-obstacle .tile-label{display:none !important;}

/* FORCE visible tree + rock sprites */
.tile.player-obstacle {
  background: none !important;
}
.tile.player-obstacle::after {
  content: "";
  position: absolute;
  inset: 0;
  background: var(--tree-img, url(assets/tree1.png)) center/contain no-repeat;
  pointer-events: none;
}

.tile.random-obstacle {
  background: none !important;
}
.tile.random-obstacle::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url(assets/rock.png) center/contain no-repeat;
  pointer-events: none;
}

.passive-active-note{
  margin-top:4px;
  font-size:12px;
  color:#d8f0ff;
  background:rgba(87,168,255,0.18);
  border:1px solid rgba(87,168,255,0.35);
  padding:2px 6px;
  border-radius:6px;
  display:inline-block;
}
.enemy-hp-bar{
  position:absolute;
  width:18px;
  height:4px;
  margin-left:-9px;
  background:rgba(0,0,0,0.35);
  border:1px solid rgba(255,255,255,0.25);
  border-radius:4px;
  overflow:hidden;
  pointer-events:none;
}
.enemy-hp-fill{
  height:100%;
  background:#75dd8c;
}

/* gold/jewel update + relic popup */
.left-panel .meta-currency{
  margin-top:10px;
  padding:10px;
  font-size:0.85rem;
  line-height:1.35;
}
.meta-title{font-weight:800; margin-bottom:6px;}
.meta-rewards{margin-top:6px; color:var(--muted); font-size:0.8rem;}
.center-panel{
  background: transparent !important;
  border-color: rgba(0,0,0,0) !important;
  box-shadow:none !important;
}
.grid{
  background: transparent !important;
}
.tile{
  background: rgba(122,101,47,0.16) !important;
  backdrop-filter: none;
}
.tile.portal{
  background: rgba(122,101,47,0.16) !important;
}
.relic-section{ display:none; }
.relic-modal{
  position:fixed;
  inset:0;
  background: rgba(0,0,0,0.45);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:1000;
}
.relic-modal.hidden{ display:none; }
.relic-modal-card{
  width:min(720px, 90vw);
  max-height:80vh;
  overflow:auto;
  padding:16px;
}
.relic-modal-title{
  font-size:1.25rem;
  font-weight:800;
  text-align:center;
  margin-bottom:12px;
}

/* repeat patch: darker tiles + stronger hero tint */
.tile{
  background: rgba(122,101,47,0.31) !important;
}
.tile.portal{
  background: rgba(122,101,47,0.31) !important;
}
.tile-hero-warrior { background: linear-gradient(180deg, rgba(79,136,255,0.26), rgba(122,101,47,0.94)) !important; }
.tile-hero-archer { background: linear-gradient(180deg, rgba(62,159,108,0.26), rgba(122,101,47,0.94)) !important; }
.tile-hero-wizard { background: linear-gradient(180deg, rgba(142,101,255,0.26), rgba(122,101,47,0.94)) !important; }
.tile-hero-priest { background: linear-gradient(180deg, rgba(209,219,141,0.28), rgba(122,101,47,0.94)) !important; }
.tile-hero-pirate { background: linear-gradient(180deg, rgba(207,138,55,0.28), rgba(122,101,47,0.94)) !important; }

/* latest tweak: darker tiles + single tree color */
.tile{
  background: rgba(122,101,47,0.46) !important;
}
.tile.portal{
  background: rgba(122,101,47,0.46) !important;
}

/* latest fix: remove selected title spacing and stop page jump */
.right-panel{
  min-height: 900px;
  height: 900px;
  overflow-y: auto;
  overflow-x: hidden;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}
.selected-info{
  min-height: 131px;
  max-height: 103px;
  overflow-y: auto;
}
.abilities-panel{
  overflow-y: auto;
  overflow-x: hidden;
  overflow-y: auto;
  flex: 1 1 auto;
  min-height: 0;
}
.passive-card p, .selected-info, .ability-banner{
  overflow-wrap: anywhere;
}

.tile.spawn{
  background: url(assets/void.png) center/cover no-repeat !important;
  border-color: rgba(188,118,255,0.55) !important;
  box-shadow: inset 0 0 0 1px rgba(255,210,90,0.18), 0 0 10px rgba(142,61,255,0.15);
}

/* latest visual pass */
body{
  background: transparent !important;
  min-height: 100dvh;
}
.tile{
  background: rgba(122,101,47,0.66) !important;
}
.tile.portal{
  background: rgba(122,101,47,0.66) !important;
}
.tile.player-obstacle{
  background: none !important;
}
.tile.player-obstacle::after{
  content:"";
  position:absolute;
  inset:0;
  background: var(--tree-img, url(assets/tree1.png)) center/contain no-repeat;
  pointer-events:none;
}
.tile.random-obstacle{
  background: none !important;
}
.tile.random-obstacle::after{
  content:"";
  position:absolute;
  inset:0;
  background: url(assets/rock.png) center/contain no-repeat;
  pointer-events:none;
}
.tile.spawn{
  background: url(assets/void.png) center/cover no-repeat !important;
}

/* request pass: darker tiles, bigger enemies, distinct ability visuals */
.tile{
  background: rgba(122,101,47,0.79) !important;
}
.tile.portal{
  background: rgba(122,101,47,0.79) !important;
}
.enemy-dot{
  transform: translate(-50%, -50%);
  transform-origin:center center;
}
.enemy-hp-bar{
  width:24px;
  height:5px;
  margin-left:-12px;
}
.attack-line-wizard-fireball{
  stroke:#d68cff;
  stroke-width:2.2;
  opacity:0.95;
}
.attack-line-archer-multishot{
  stroke:#9be78f;
  stroke-width:1.8;
  opacity:0.95;
  stroke-dasharray:3 2;
}

/* status overlay stacked below the battlefield */
.center-panel{
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.grid{
  order: 1;
  flex-shrink: 0;
}
.status-overlay{
  order: 2;
  position: relative;
  left: auto;
  right: auto;
  top: auto;
  bottom: auto;
  transform: none;
  z-index: 30;
  max-width:min(calc(100% - 16px), calc(13 * var(--tile-size) + 12 * var(--tile-gap) - 16px));
  width:max-content;
  min-height: 46px;
  margin:6px auto 0;
  padding:10px 18px;
  border-radius:14px;
  background:rgba(26,35,51,0.92);
  border:1px solid rgba(78,98,138,0.75);
  box-shadow:0 10px 24px rgba(0,0,0,0.28);
  color:var(--text);
  font-size:0.95rem;
  line-height:1.25;
  text-align:center;
  pointer-events:none;
  opacity:1;
  visibility: visible;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:0;
  flex-wrap:wrap;
  box-sizing: border-box;
}
.status-overlay.hidden{
  visibility:hidden;
  opacity:0;
}
.status-overlay .phase-label{
  display:inline;
  margin-right:10px;
  color:#f0d85e;
  font-weight:800;
}
.status-overlay .instruction{
  display:inline;
  margin:0;
  color:var(--text);
}
.bottom-panel{
  order: 3;
}


/* tweak pass: easy/challenge labels, obstacle darkness retained */
.tile.player-obstacle,
.tile.random-obstacle{
  background: rgba(122,101,47,0.79) !important;
}
.tile.player-obstacle::after,
.tile.random-obstacle::after{
  z-index: 1;
  opacity: 0.94;
  filter: brightness(0.9) saturate(0.95);
}
.tile.player-obstacle::before,
.tile.random-obstacle::before{
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(24,18,10,0.16);
  pointer-events: none;
  z-index: 2;
}
.tile-label,
.tile-hp,
.tile-charge,
.tile-effect,
.tile-path-preview{
  position: relative;
  z-index: 3;
}

.wallet-panel {
  margin-top: 10px;
  padding: 10px;
}

.wallet-panel-toggle {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 0;
  border: 0;
  background: transparent;
  color: var(--text);
  cursor: pointer;
}
.wallet-panel-toggle .meta-title {
  margin: 0;
}
.wallet-panel-chevron {
  color: #d9b679;
  font-size: 0.95rem;
  transition: transform 0.16s ease;
}
.wallet-panel-body {
  margin-top: 8px;
}
.wallet-panel.collapsed .wallet-panel-body {
  display: none;
}
.wallet-panel.collapsed .wallet-panel-chevron {
  transform: rotate(-90deg);
}

#bankPanel .wallet-panel-toggle {
  margin-bottom: 0;
}
#bankPanel .bank-panel-body {
  display: grid;
  gap: 8px;
  padding-top: 10px;
}
#bankPanel.collapsed .bank-panel-body {
  display: none;
}
#bankPanel.collapsed .wallet-panel-chevron {
  transform: rotate(-90deg);
}
.wallet-status {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  font-weight: 800;
  font-size: 0.42rem;
  letter-spacing: 0.02em;
  color: #dfe9ff;
}
.wallet-status.wallet-good::before {
  content: '';
  width: 3px;
  height: 3px;
  border-radius: 999px;
  background: currentColor;
  flex: 0 0 3px;
}
.wallet-panel-title-row {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  min-width: 0;
}
.wallet-panel-title-row .meta-title {
  margin-bottom: 0;
}
.wallet-vanity-section.hidden {
  display: none !important;
}

.wallet-vanity-section {
  display: grid;
  gap: 8px;
}
.wallet-vanity-row {
  display: flex;
  align-items: center;
  gap: 6px;
}
.wallet-vanity-input {
  flex: 1 1 auto;
  min-width: 0;
  width: 85%;
  min-height: 30px;
  border-radius: 8px;
  border: 1px solid #4d5f87;
  background: rgba(20, 28, 48, 0.92);
  color: var(--text);
  padding: 0 10px;
  font-size: 0.74rem;
}
.wallet-vanity-input::placeholder {
  color: #9fb2d8;
}
.vanity-btn {
  flex: 0 0 auto;
  min-width: 76px;
  padding: 0 10px;
  white-space: nowrap;
}

.wallet-profile-name,
.wallet-profile-balance {
  margin-top: 6px;
  font-size: 0.78rem;
  color: #dfe9ff;
  line-height: 1.3;
}
#walletProfileName,
#walletAddress {
  display: none !important;
}
.wallet-profile-balance {
  color: #d9b679;
  font-weight: 700;
}
.wallet-address {
  margin-top: 6px;
  font-size: 0.72rem;
  color: var(--muted);
  line-height: 1.3;
  word-break: break-all;
}
.wallet-tracking-status,
.wallet-tracking-summary {
  margin-top: 6px;
  font-size: 0.72rem;
  line-height: 1.3;
}
.wallet-tracking-status {
  color: #dfe9ff;
}
.wallet-tracking-status.good {
  color: #8ff0a4;
}
.wallet-tracking-status.warn {
  color: #f3d37a;
}
.wallet-tracking-status.bad {
  color: #ff9a9a;
}
.wallet-tracking-summary {
  color: var(--muted);
  font-size: 0.9rem;
}
.tracking-btn {
  width: 100%;
  margin-top: 6px;
}
.wallet-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5px;
  margin-top: 8px;
}
.wallet-btn {
  min-height: 28px;
  padding: 0 10px;
  border-radius: 8px;
  border: 1px solid #4d5f87;
  background: linear-gradient(180deg, #2e3f63, #24334f);
  color: var(--text);
  font-size: 0.72rem;
  font-weight: 700;
  cursor: pointer;
}
.wallet-btn.secondary {
  background: linear-gradient(180deg, #304a5d, #243948);
}
.wallet-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}
.wallet-bankline {
  margin-top: 8px;
  font-size: 0.76rem;
  color: var(--text);
  line-height: 1.25;
}
.wallet-note {
  margin-top: 8px;
  font-size: 0.68rem;
  line-height: 1.35;
  color: var(--muted);
}
.wallet-good { color: #7be28c; }
.wallet-warn { color: #ffd479; }
.wallet-bad { color: #ff9f9f; }


.intro-toggle {
  margin-top: 8px;
  width: 100%;
  min-height: 34px;
  border-radius: 10px;
  border: 1px solid #8b6d3d;
  background: linear-gradient(180deg, #6e5530, #574224);
  color: #f5ead5;
  font-size: 0.82rem;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.12s ease, background 0.12s ease, border-color 0.12s ease;
}
.intro-toggle:hover { transform: translateY(-1px); border-color: #d0aa68; }
.intro-toggle:focus-visible { outline: 2px solid #e1bf80; outline-offset: 2px; }
.intro-toggle.secondary-guide {
  margin-top: 6px;
  background: linear-gradient(180deg, #5c4728, #47351d);
  border-color: #775a31;
}
.intro-toggle.secondary-guide:hover { border-color: #c59c60; }

.intro-modal {
  position: fixed;
  inset: 0;
  z-index: 20000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18px;
  background: rgba(26, 17, 8, 0.74);
  backdrop-filter: blur(3px);
}
.intro-modal-card {
  width: min(760px, calc(100vw - 28px));
  max-height: min(760px, calc(100vh - 32px));
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border: 1px solid #8a6836;
  background:
    radial-gradient(circle at top, rgba(225, 191, 128, 0.08), transparent 35%),
    linear-gradient(180deg, rgba(77, 54, 24, 0.98), rgba(48, 34, 17, 0.98));
  box-shadow: 0 16px 40px rgba(0,0,0,0.45);
}
.intro-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  padding: 16px 18px 12px;
  border-bottom: 1px solid rgba(202, 157, 90, 0.24);
}
.intro-kicker {
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #d9b679;
  margin-bottom: 4px;
}
#introTitle {
  margin: 0;
  color: #f4e7cf;
  font-size: 1.35rem;
  line-height: 1.15;
}
.intro-close {
  min-width: 36px;
  min-height: 36px;
  padding: 0;
  border-radius: 10px;
  border: 1px solid #8b6d3d;
  background: linear-gradient(180deg, #6b4f2a, #573f22);
  color: #f7e7cb;
  font-size: 1.2rem;
}
.intro-body {
  padding: 18px;
  overflow: auto;
  color: #f0e4cf;
  line-height: 1.55;
  font-size: 0.96rem;
}
.intro-page-heading {
  margin: 0 0 10px;
  color: #f7deb1;
  font-size: 1.08rem;
}
.intro-page-subheading {
  margin: 14px 0 6px;
  color: #e7c181;
  font-size: 0.9rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.intro-body p {
  margin: 0 0 11px;
}
.intro-body ul {
  margin: 0 0 11px 18px;
  padding: 0;
}
.intro-body li {
  margin: 0 0 6px;
}
.intro-highlight {
  color: #ffde9d;
  font-weight: 700;
}

.intro-section-card {
  margin: 0 0 12px;
  padding: 12px 13px;
  border: 1px solid rgba(202, 157, 90, 0.18);
  border-radius: 12px;
  background: linear-gradient(180deg, rgba(255, 238, 205, 0.05), rgba(255, 238, 205, 0.02));
}
.intro-section-card:last-child {
  margin-bottom: 0;
}
.intro-compact-list {
  margin: 0 0 2px 18px;
}
.intro-compact-list li {
  margin-bottom: 5px;
}

.intro-modal-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 12px 18px 16px;
  border-top: 1px solid rgba(202, 157, 90, 0.24);
}
.intro-page-label {
  color: #d7bf94;
  font-size: 0.8rem;
  text-align: center;
  flex: 1 1 auto;
}
.intro-modal-footer .small-action,
.intro-modal-footer .secondary {
  min-width: 112px;
  background: linear-gradient(180deg, #7b5f34, #5f4725);
  border: 1px solid #a58149;
  color: #fff1d6;
}
.intro-modal-footer .secondary {
  background: linear-gradient(180deg, #5e4930, #483520);
}
.intro-modal-footer .small-action:disabled,
.intro-modal-footer .secondary:disabled {
  opacity: 0.4;
}
/* Responsive breakpoints
   360px  : mobile
   568px  : small landscape
   666px  : large landscape
   768px  : tablet
   1024px : large tablet / small laptop
   1300px : full desktop threshold
   2500px : large monitors
*/

.mobile-right-menu-toggle {
  display: none;
}

@media (max-width: 1024px) {
  .intro-modal { padding: 10px; }
  .intro-modal-card {
    width: min(100%, calc(100vw - 12px));
    max-height: calc(100vh - 16px);
  }
  .intro-modal-footer {
    flex-wrap: wrap;
  }
  .intro-modal-footer .small-action,
  .intro-modal-footer .secondary {
    flex: 1 1 140px;
  }
}



.mobile-side-menu-toggle {
  display: none;
}
.mobile-hud,
.mobile-menu-overlay,
.mobile-menu-shell,
.mobile-menu-card,
.mobile-bottom-bar,
.mobile-bar-toggle {
  display: none;
}


.mobile-install-prompt {
  position: fixed;
  left: calc(10px + env(safe-area-inset-left));
  right: calc(10px + env(safe-area-inset-right));
  bottom: 74px;
  z-index: 1240;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 14px;
  border: 1px solid rgba(145, 170, 221, 0.35);
  background: rgba(17, 25, 38, 0.92);
  box-shadow: 0 12px 26px rgba(0, 0, 0, 0.34);
}
.mobile-install-prompt.hidden {
  display: none;
}
.mobile-install-text {
  font-size: 0.78rem;
  line-height: 1.25;
  color: #e6efff;
}
.mobile-install-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}
.mobile-install-btn,
.mobile-install-dismiss {
  border-radius: 10px;
  border: 1px solid #4d5f87;
  color: var(--text);
  background: linear-gradient(180deg, #2d3f61, #22324d);
  font-size: 0.78rem;
  font-weight: 700;
}
.mobile-install-btn {
  min-height: 36px;
  padding: 0 12px;
}
.mobile-install-dismiss {
  width: 34px;
  min-width: 34px;
  min-height: 34px;
  padding: 0;
}
.mobile-hud.bar-collapsed .mobile-install-prompt {
  left: calc(44px + env(safe-area-inset-left));
}

.mobile-menu-overlay {
  position: fixed;
  inset: 0;
  border: 0;
  background: rgba(8, 12, 20, 0.6);
  z-index: 1200;
}

.mobile-menu-shell {
  position: fixed;
  inset: 10px 10px 72px 10px;
  z-index: 1210;
  pointer-events: none;
  align-items: center;
  justify-content: center;
}

.mobile-menu-card {
  pointer-events: auto;
  width: min(440px, calc(100vw - 28px));
  max-height: min(58vh, 300px);
  overflow: auto;
  border-radius: 16px;
  border: 1px solid rgba(145, 170, 221, 0.35);
  background: rgba(23, 32, 48, 0.94);
  box-shadow: 0 16px 34px rgba(0, 0, 0, 0.38);
  padding: 12px;
}

.mobile-menu-title {
  font-size: 0.8rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  color: #dfe8ff;
  margin-bottom: 10px;
}

.mobile-menu-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
}

.mobile-menu-actions button,
.mobile-hero-host .action-group button,
.mobile-hire-host .card button,
.mobile-bottom-btn {
  min-height: 40px;
}

.mobile-menu-actions button,
.mobile-bottom-btn {
  border-radius: 10px;
  border: 1px solid #4d5f87;
  background: linear-gradient(180deg, #2d3f61, #22324d);
  color: var(--text);
  font-size: 0.82rem;
  font-weight: 700;
}

.mobile-bottom-bar {
  position: fixed;
  left: 42px;
  right: 8px;
  bottom: 8px;
  z-index: 1220;
  padding: 8px;
  gap: 6px;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  transition: transform 180ms ease, opacity 180ms ease;
}

.mobile-bar-toggle {
  position: fixed;
  left: 8px;
  bottom: 12px;
  z-index: 1230;
  width: 28px;
  height: 52px;
  border-radius: 12px;
  border: 1px solid #4d5f87;
  background: linear-gradient(180deg, rgba(45, 63, 97, 0.96), rgba(34, 50, 77, 0.96));
  color: var(--text);
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.34);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.mobile-bar-toggle-chevron {
  font-size: 1rem;
  font-weight: 800;
  line-height: 1;
}

.mobile-bar-toggle-notice {
  position: absolute;
  top: 5px;
  right: 4px;
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #8dff9c;
  box-shadow: 0 0 0 2px rgba(13, 23, 38, 0.88), 0 0 10px rgba(141, 255, 156, 0.75);
}

.mobile-bar-toggle.has-notice .mobile-bar-toggle-notice {
  display: block;
}

.mobile-bar-toggle-notice.hidden {
  display: none;
}

.mobile-hud.bar-collapsed .mobile-bottom-bar {
  transform: translateX(calc(-100% - 16px));
  opacity: 0;
  pointer-events: none;
}

.mobile-hud.bar-collapsed .mobile-bar-toggle-chevron {
  transform: rotate(180deg);
}

.mobile-bottom-btn {
  width: 100%;
  padding: 0 4px;
}

.mobile-bottom-btn.active {
  background: linear-gradient(180deg, #5d52ff, #4a3fd1);
  border-color: #9aa4ff;
}

.mobile-bottom-btn:disabled {
  opacity: 0.48;
}

.mobile-ability-btn {
  font-size: 0.76rem;
}

.mobile-hero-host {
  display: grid;
  gap: 10px;
}

.mobile-hero-host .selected-info {
  max-height: 67px;
  min-height: 134px;
  overflow: auto;
  scrollbar-width: none;
}
.mobile-hero-host .selected-info::-webkit-scrollbar { width: 0; height: 0; }
.mobile-hero-host .selected-info:hover,
.mobile-hero-host .selected-info:focus-within { scrollbar-width: thin; }
.mobile-hero-host .selected-info:hover::-webkit-scrollbar,
.mobile-hero-host .selected-info:focus-within::-webkit-scrollbar { width: 8px; }
.mobile-hero-host .selected-info:hover::-webkit-scrollbar-thumb,
.mobile-hero-host .selected-info:focus-within::-webkit-scrollbar-thumb { background: rgba(169, 182, 211, 0.5); border-radius: 999px; }
.mobile-hero-host .action-group { display: grid; gap: 8px; }
.mobile-hero-host .abilities-panel { display: none !important; }

.mobile-hire-host .hire-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
}

.mobile-hire-host .card {
  margin: 0;
}

.mobile-side-rail {
  display: none;
}

.mobile-side-host > .panel-lite,
.mobile-side-host > .wallet-panel,
.mobile-side-host > .topbar {
  margin: 0;
}

@media (max-width: 1024px) {
  #app {
    padding: 6px;
  }

  .main-layout {
    grid-template-columns: 1fr;
    gap: 6px;
  }

  .left-panel,
  .right-panel,
  .bottom-panel {
    display: none !important;
  }

  .center-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    padding-top: 0;
    padding-bottom: 0;
    padding-left: calc(64px + 12px + env(safe-area-inset-left));
    padding-right: calc(12px + env(safe-area-inset-right));
    min-height: calc(var(--app-vh, 1vh) * 100 - 82px);
    overflow: hidden;
  }

  .grid {
    transform-origin: top left;
    max-width: none;
    width: max-content;
    margin: 4px 0 0;
    --mobile-board-w: calc(100vw - 64px - 20px - env(safe-area-inset-left) - env(safe-area-inset-right));
    --mobile-board-h: calc((var(--app-vh, 1vh) * 100) - 84px - env(safe-area-inset-top) - env(safe-area-inset-bottom));
    --tile-size: min(calc(var(--mobile-board-w) / 14), calc(var(--mobile-board-h) / 6), 58px);
  }

  .status-overlay {
    left: auto;
    right: auto;
    top: auto;
    bottom: auto;
    transform: none;
    max-width: min(72%, 560px);
    width: max-content;
    margin: 5px auto 0;
    padding: 8px 14px;
    font-size: 0.86rem;
    line-height: 1.2;
  }

  @media (orientation: landscape) {
    .grid {
      --tile-gap: 2px;
    }
  }

  .mobile-hud {
    display: block;
  }

  .mobile-side-rail {
    position: fixed;
    top: 56px;
    bottom: calc(70px + env(safe-area-inset-bottom));
    z-index: 1215;
    display: grid;
    align-content: start;
    gap: 8px;
    pointer-events: none;
  }

  .mobile-side-rail > * {
    pointer-events: auto;
  }

  .mobile-left-rail {
    left: calc(6px + env(safe-area-inset-left));
    width: 96px;
    transition: transform 0.22s ease;
  }

  .mobile-left-rail.collapsed {
    transform: translateX(calc(-100% - 6px));
  }

  .mobile-side-menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    left: calc(4px + env(safe-area-inset-left));
    top: 50%;
    transform: translateY(-50%);
    z-index: 1225;
    width: 22px;
    height: 42px;
    padding: 0;
    border-radius: 0 12px 12px 0;
    border: 2px solid rgba(59, 206, 231, 0.95);
    background: rgba(24, 34, 53, 0.92);
    color: var(--text);
    box-shadow: 0 8px 18px rgba(0,0,0,0.25);
  }

  .mobile-right-rail {
    right: calc(6px + env(safe-area-inset-right));
    width: 96px;
    top: 56px;
    transition: transform 0.22s ease;
  }

  .mobile-right-rail.collapsed {
    transform: translateX(calc(100% + 6px));
  }

  .mobile-right-menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: fixed;
    right: calc(4px + env(safe-area-inset-right));
    top: 50%;
    transform: translateY(-50%);
    z-index: 1225;
    width: 22px;
    height: 42px;
    padding: 0;
    border-radius: 12px 0 0 12px;
    border: 2px solid rgba(39, 210, 126, 0.95);
    background: rgba(24, 34, 53, 0.92);
    color: var(--text);
    box-shadow: 0 8px 18px rgba(0,0,0,0.25);
  }

  .mobile-left-rail .panel-lite,
  .mobile-left-rail .wallet-panel,
  .mobile-right-rail .topbar {
    border-radius: 18px;
    background: rgba(120, 94, 8, 0.82);
    border: 2px solid rgba(59, 206, 231, 0.95);
    padding: 6px;
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.28);
  }


  .mobile-left-rail .wallet-panel-toggle,
  .mobile-left-rail #bankPanel .wallet-panel-toggle {
    min-height: 34px;
    padding: 6px 8px;
    justify-content: center;
  }

  .mobile-left-rail .wallet-panel-toggle .meta-title,
  .mobile-left-rail #bankPanel .wallet-panel-toggle .meta-title {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-align: center;
  }

  .mobile-left-rail .wallet-panel-body,
  .mobile-left-rail #bankPanel .bank-panel-body {
    padding-top: 8px;
    display: grid;
    gap: 8px;
    font-size: 0.66rem;
    line-height: 1.15;
  }

  .mobile-left-rail .wallet-actions {
    grid-template-columns: 1fr;
  }

  .mobile-left-rail .wallet-btn {
    min-height: 30px;
    font-size: 0.62rem;
    padding: 0 6px;
  }

  .mobile-left-rail .wallet-note,
  .mobile-left-rail .wallet-address,
  .mobile-left-rail .wallet-status,
  .mobile-left-rail .wallet-bankline,
  .mobile-left-rail .meta-rewards {
    font-size: 0.62rem;
    line-height: 1.15;
    word-break: break-word;
  }

  .mobile-right-rail .mobile-stats-panel {
    display: grid;
    gap: 0;
  }

  .mobile-right-rail .wallet-panel-toggle {
    min-height: 34px;
    padding: 6px 8px;
    justify-content: center;
  }

  .mobile-right-rail .wallet-panel-toggle .meta-title {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-align: center;
  }

  .mobile-right-rail .mobile-stats-body {
    padding-top: 8px;
  }

  .mobile-right-rail .topbar {
    border-color: rgba(39, 210, 126, 0.95);
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
    min-height: auto;
    align-content: start;
    padding: 6px;
  }

  .mobile-right-rail .topbar > div,
  .mobile-right-rail .topbar > div:nth-child(n+4) {
    display: grid;
    justify-items: start;
    text-align: left;
    gap: 2px;
  }

  .mobile-right-rail .topbar strong,
  .mobile-right-rail .topbar span {
    font-size: 0.68rem;
    line-height: 1.1;
  }

  .mobile-hud.hidden { display: block; }

  .mobile-menu-overlay:not(.hidden) {
    display: block;
  }

  .mobile-menu-shell:not(.hidden) {
    display: flex;
  }

  .mobile-menu-card:not(.hidden) {
    display: block;
  }

  .mobile-bar-toggle {
    display: flex;
  }

  .mobile-bottom-bar {
    display: grid;
  }
}

@media (max-width: 666px) and (orientation: landscape) {
  .mobile-install-prompt {
    bottom: 66px;
    padding: 8px 10px;
  }

  .center-panel {
    padding-left: calc(22px + env(safe-area-inset-left));
    padding-right: calc(22px + env(safe-area-inset-right));
  }

  .mobile-side-rail {
    top: 52px;
    bottom: calc(66px + env(safe-area-inset-bottom));
  }

  .mobile-left-rail {
    width: 90px;
  }

  .mobile-right-rail {
    width: 88px;
  }

  .mobile-bottom-bar {
    left: 40px;
    gap: 4px;
    padding: 6px;
  }

  .mobile-bar-toggle {
    height: 48px;
  }

  .mobile-bottom-btn {
    min-height: 36px;
    font-size: 0.72rem;
  }

  .mobile-menu-card {
    width: calc(100vw - 20px);
    max-height: min(62vh, 280px);
    padding: 10px;
  }
}

@media (max-width: 568px) and (orientation: landscape) {
  .mobile-install-text {
    font-size: 0.72rem;
  }

  .mobile-install-btn {
    min-height: 34px;
    padding: 0 10px;
  }

  .center-panel {
    padding-left: calc(20px + env(safe-area-inset-left));
    padding-right: calc(20px + env(safe-area-inset-right));
  }

  .mobile-left-rail {
    width: 56px;
  }

  .mobile-right-rail {
    width: 82px;
  }

  .grid {
    --mobile-board-w: calc(100vw - 56px - 22px - env(safe-area-inset-left) - env(safe-area-inset-right));
    --mobile-board-h: calc((var(--app-vh, 1vh) * 100) - 84px - env(safe-area-inset-top) - env(safe-area-inset-bottom));
    --tile-size: min(calc(var(--mobile-board-w) / 14), calc(var(--mobile-board-h) / 6), 56px);
    --tile-gap: 2px;
  }
}

@media (max-width: 360px) and (orientation: landscape) {
  .mobile-install-prompt {
    bottom: 62px;
    gap: 8px;
    padding: 8px;
  }

  .mobile-install-text {
    font-size: 0.68rem;
  }

  .center-panel {
    padding-left: calc(56px + 10px + env(safe-area-inset-left));
    padding-right: calc(10px + env(safe-area-inset-right));
  }

  .mobile-left-rail {
    width: 48px;
  }

  .mobile-right-rail {
    width: 78px;
  }

  .grid {
    --tile-size: calc(min(calc((100vw - 52px - env(safe-area-inset-left) - env(safe-area-inset-right)) / 14), calc((var(--app-vh, 1vh) * 100 - 112px) / 6), 44px) * 1.47);
  }

  .mobile-bottom-btn {
    font-size: 0.66rem;
    min-height: 34px;
  }
}


@media (min-width: 1025px) {
  .center-panel {
    padding-top: 8px;
    padding-bottom: 42px;
  }

  .grid {
    margin-top: 25px;
  }

  .status-overlay {
    top: auto;
    bottom: auto;
    left: auto;
    transform: none;
    max-width: min(76%, 900px);
    margin: 5px auto 0;
  }
}

/* === user-requested desktop layout alignment === */
@media (min-width: 1025px) {
  .center-panel {
    padding-top: 0;
    padding-bottom: 6px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .status-overlay {
    position: relative;
    top: auto;
    bottom: auto;
    left: auto;
    transform: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: max-content;
    max-width: min(calc(13 * var(--tile-size) + 12 * var(--tile-gap) - 16px), calc(100% - 16px));
    margin: 5px auto 0;
    z-index: 30;
  }

  .status-overlay.hidden {
    visibility: hidden !important;
    opacity: 0 !important;
  }

  .grid {
    margin: 0 auto;
  }

  .bottom-panel {
    width: min(calc(13 * var(--tile-size) + 12 * var(--tile-gap)), calc(100% - 8px));
    max-width: calc(13 * var(--tile-size) + 12 * var(--tile-gap));
    margin: 0 auto 3px;
    order: 0;
    padding: 6px 8px 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;
    z-index: 6;
  }

  .controls-row.action-row {
    gap: 8px;
    align-items: center;
    flex-wrap: nowrap;
  }

  .footer-topbar {
    width: 100%;
    margin-left: 6px;
  }

  .controls-stack {
    margin-top: 0;
    gap: 0;
  }

  .control-section.hire-section {
    min-height: 122px;
  }

  .hire-section {
    margin-top: 0;
  }

  .hire-list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 8px;
    direction: rtl;
  }

  .hire-list > * {
    direction: ltr;
  }

  .hire-list .card {
    min-height: 112px;
  }

  .relic-section {
    display: none;
  }
}

@media (min-width: 1025px) and (max-width: 1200px) {
  .footer-topbar {
    width: auto;
  }

  .controls-row.action-row {
    flex-wrap: wrap;
  }

  .hire-list {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    direction: ltr;
  }
}


/* Simplified hire panel: buttons only */
.hire-section {
  min-height: 0;
}

.hire-list {
  min-height: 0;
  gap: 6px;
  align-items: center;
}

.hire-list .card,
.hire-button-card {
  background: transparent;
  border: 0;
  padding: 0;
  min-height: 0;
  box-shadow: none;
}

.hire-list .card h4,
.hire-list .card p {
  display: none;
}

.hire-list .card button {
  width: 100%;
}

.control-section.hire-section {
  min-height: 0;
}

.bottom-panel .controls-stack {
  gap: 4px;
}


.tile {
  overflow: hidden;
}

.tile-hero-portrait {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center bottom;
  padding: 2px;
  image-rendering: pixelated;
  z-index: 1;
  pointer-events: none;
}

.tile-hero-portrait-underlay {
  opacity: 0.42;
  filter: saturate(0.9) brightness(0.98);
}


.tile-ethereal-hero {
  filter:
    brightness(1.08)
    saturate(1.35)
    drop-shadow(0 0 10px var(--ethereal-glow, rgba(255,255,255,0.85)))
    drop-shadow(0 0 22px var(--ethereal-glow, rgba(255,255,255,0.72)))
    drop-shadow(0 0 36px var(--ethereal-glow, rgba(255,255,255,0.48)));
}

.tile-archer-shadow-hero {
  filter: brightness(0.42) saturate(0.3) contrast(1.18) drop-shadow(0 0 5px rgba(20, 20, 28, 0.92)) drop-shadow(0 0 12px rgba(65, 65, 88, 0.55));
}
.tile-archer-shadow-label {
  color: #d8ddf0;
  text-shadow: 0 0 6px rgba(18, 20, 34, 0.95), 0 0 12px rgba(62, 66, 96, 0.72);
  letter-spacing: 0.08em;
}
.tile-ethereal-label {
  text-shadow:
    0 0 10px var(--ethereal-glow, rgba(255,255,255,0.9)),
    0 0 18px var(--ethereal-glow, rgba(255,255,255,0.72)),
    0 0 28px var(--ethereal-glow, rgba(255,255,255,0.45)),
    -1px -1px 0 #fff,
     1px -1px 0 #fff,
    -1px 1px 0 #fff,
     1px 1px 0 #fff;
}

.tile-statue-hero {
  filter: grayscale(1) brightness(1.05) contrast(1.1);
}

.tile-statue-label {
  color: #222;
  text-shadow:
    0 0 6px rgba(255,255,255,0.4),
    -1px -1px 0 #d7d7d7,
     1px -1px 0 #d7d7d7,
    -1px 1px 0 #d7d7d7,
     1px 1px 0 #d7d7d7;
}

.tile-archon-sparkle::before,
.tile-archon-sparkle::after {
  content: '✦';
  position: absolute;
  z-index: 3;
  font-size: 13px;
  color: rgba(245, 230, 255, 0.95);
  text-shadow: 0 0 6px rgba(190, 140, 255, 0.95), 0 0 12px rgba(255,255,255,0.85);
  animation: archonSparkle 1.6s ease-in-out infinite;
  pointer-events: none;
}

.tile-archon-sparkle::before {
  top: 3px;
  left: 4px;
}

.tile-archon-sparkle::after {
  right: 5px;
  bottom: 10px;
  animation-delay: 0.8s;
}

@keyframes archonSparkle {
  0%, 100% { transform: scale(0.7); opacity: 0.35; }
  50% { transform: scale(1.2); opacity: 1; }
}

.tower-chip,
.tile-small,
.hp-bar,
.cooldown-bar,
.tile-hover-card,
.hit-text {
  position: relative;
  z-index: 2;
}

.hp-bar,
.cooldown-bar {
  left: 6%;
  width: 88%;
}

.hp-bar {
  top: auto;
  bottom: 10%;
}

.cooldown-bar {
  top: auto;
  bottom: 4%;
}



/* Hero tile portrait/layout adjustments */
.tower-chip {
  display: none !important;
}



.hp-bar,
.cooldown-bar {
  left: 6%;
  width: 88%;
  top: auto !important;
}

.hp-bar {
  bottom: 14px !important;
}

.cooldown-bar {
  bottom: 4px !important;
}

.tile-hero-portrait {
  z-index: 1;
}


/* === Bar swap: health fully inside black area above activity === */
.hp-bar,
.cooldown-bar {
  position: absolute;
  left: 8%;
  width: 84%;
  z-index: 3;
}

/* Health bar sits clearly inside black strip */
.hp-bar {
  bottom: 12px !important;
  height: 6px;
}

/* Activity bar below it */
.cooldown-bar {
  bottom: 4px !important;
  height: 4px;
}





/* Hero header text inside colored strip */


/* Level tucked directly under class text */



/* Left-aligned header text inside colored strip */


/* Level left-aligned under class text, +25% size */



/* Center class text */
.tile-hero-label {
  position: absolute;
  top: 1px;
  left: 0;
  width: 100%;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 4;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 0.4px;
  color: #000;
  text-transform: uppercase;
  pointer-events: none;
  text-shadow:
    -1px -1px 0 #fff,
     1px -1px 0 #fff,
    -1px  1px 0 #fff,
     1px  1px 0 #fff;
}

/* Lv left aligned and lowered */
/* Level number only, larger */
.tile-small {
  position: absolute;
  top: 22px;
  left: 6px;
  font-size: 14px; /* ~25% increase */
  font-weight: 900;
  color: #000;
  background: rgba(255,255,255,0.35);
  padding: 1px 4px;
  border-radius: 3px;
  z-index: 4;
  text-shadow:
    -1px -1px 0 #fff,
     1px -1px 0 #fff,
    -1px  1px 0 #fff,
     1px  1px 0 #fff;
}

.tile-small-right {
  left: auto;
  right: 6px;
  min-width: 18px;
  text-align: center;
}



.slow-totem-badge {
  position: absolute;
  right: 4px;
  bottom: 28px;
  z-index: 4;
  font-size: 8px;
  font-weight: 900;
  color: #0d2230;
  background: rgba(180, 255, 255, 0.8);
  border: 1px solid rgba(255,255,255,0.85);
  border-radius: 3px;
  padding: 1px 3px;
  line-height: 1;
  pointer-events: none;
}



/* Keep hero panel visible as viewport narrows */
@media (min-width: 901px) and (max-width: 1420px) {
  .main-layout {
    display: grid;
    grid-template-columns: minmax(220px, 0.9fr) minmax(520px, 2fr) minmax(260px, 1fr);
    gap: 12px;
    align-items: start;
  }

  .left-panel,
  .center-panel,
  .right-panel {
    min-width: 0;
  }

  .right-panel {
    position: sticky;
    top: 10px;
    align-self: start;
    max-height: calc(100dvh - 20px);
    overflow-y: auto;
  }

  #selectedInfo,
  .action-group,
  #abilitiesPanel {
    min-width: 0;
  }
}

@media (min-width: 901px) and (max-width: 1200px) {
  .main-layout {
    grid-template-columns: minmax(180px, 0.8fr) minmax(460px, 2fr) minmax(240px, 0.95fr);
    gap: 10px;
  }

  .right-panel {
    font-size: 14px;
  }
}


/* Run Log inline header toggle */
.runlog-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 10px;
}

.runlog-header h2 {
  margin: 0;
}

.runlog-inline-toggle {
  display: none;
  width: 26px;
  height: 26px;
  align-items: center;
  justify-content: center;
  border: 1px solid #3a4b70;
  border-radius: 8px;
  background: rgba(82, 95, 145, 0.28);
  color: var(--text);
  cursor: pointer;
  font-size: 16px;
  font-weight: 900;
  line-height: 1;
  flex: 0 0 auto;
}

.runlog-inline-toggle:hover {
  background: rgba(98, 112, 170, 0.42);
}

@media (min-width: 901px) {
  :root {
  --board-padding-buffer: 24px;
    --desktop-left-panel: 300px;
    --desktop-right-panel: 265px;
  }

  .main-layout {
    display: grid;
    grid-template-columns: var(--desktop-left-panel) minmax(0, 1fr) var(--desktop-right-panel);
    gap: 12px;
    align-items: start;
  }

  .runlog-inline-toggle {
    display: inline-flex;
  }

  #runLogPanel,
  .center-panel,
  .right-panel {
    min-width: 0;
  }

  #runLogPanel {
    transition: width 0.22s ease, min-width 0.22s ease, padding 0.22s ease, opacity 0.22s ease;
    overflow: hidden;
  }

  .center-panel {
    overflow: hidden;
  }

  .right-panel {
    position: sticky;
    top: 10px;
    align-self: start;
    max-height: calc(100dvh - 20px);
    overflow-y: auto;
  }

  body.runlog-collapsed {
    --desktop-left-panel: 44px;
  }

  body.runlog-collapsed #runLogPanel {
    padding-left: 8px;
    padding-right: 8px;
  }

  body.runlog-collapsed #runLogPanel .log,
  body.runlog-collapsed #runLogPanel .speed-toggle,
  body.runlog-collapsed #runLogPanel .mobile-toggle,
  body.runlog-collapsed #runLogPanel .pause-toggle,
  body.runlog-collapsed #runLogPanel .intro-toggle,
  body.runlog-collapsed #runLogPanel .meta-currency,
  body.runlog-collapsed #runLogPanel .wallet-panel,
  body.runlog-collapsed #runLogPanel .wallet-note,
  body.runlog-collapsed #runLogPanel .wallet-status,
  body.runlog-collapsed #runLogPanel .wallet-address,
  body.runlog-collapsed #runLogPanel .wallet-actions,
  body.runlog-collapsed #runLogPanel .wallet-bankline,
  body.runlog-collapsed #runLogPanel .profile-stats,
  body.runlog-collapsed #runLogPanel #leaderboardPanel {
    display: none !important;
  }

  body.runlog-collapsed #runLogPanel .runlog-header {
    justify-content: center;
  }

  body.runlog-collapsed #runLogPanel .runlog-header h2 {
    display: none;
  }
}

/* Keep hero info visible before it drops */
@media (min-width: 901px) and (max-width: 1760px) {
  :root {
  --board-padding-buffer: 24px; --tile-size: 80px; }
  .main-layout { grid-template-columns: var(--desktop-left-panel, 280px) minmax(0, 1fr) 255px; }
}
@media (min-width: 901px) and (max-width: 1660px) {
  :root {
  --board-padding-buffer: 24px; --tile-size: 74px; }
  .main-layout { grid-template-columns: var(--desktop-left-panel, 270px) minmax(0, 1fr) 248px; }
}
@media (min-width: 901px) and (max-width: 1560px) {
  :root {
  --board-padding-buffer: 24px; --tile-size: 68px; }
  .main-layout { grid-template-columns: var(--desktop-left-panel, 250px) minmax(0, 1fr) 240px; }
}
@media (min-width: 901px) and (max-width: 1460px) {
  :root {
  --board-padding-buffer: 24px; --tile-size: 62px; }
  .main-layout { grid-template-columns: var(--desktop-left-panel, 220px) minmax(0, 1fr) 228px; gap: 10px; }
}
@media (min-width: 901px) and (max-width: 1360px) {
  :root {
  --board-padding-buffer: 24px; --tile-size: 58px; --tile-gap: 5px; }
  .main-layout { grid-template-columns: var(--desktop-left-panel, 200px) minmax(0, 1fr) 220px; gap: 8px; }
  .right-panel { font-size: 14px; }
}




/* Final desktop layout: right panel always outside board, run log collapses cleanly */
