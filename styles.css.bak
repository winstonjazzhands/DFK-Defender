    font-size: 0.82rem !important;
    line-height: 1.2 !important;
    white-space: normal !important;
    overflow-wrap: anywhere !important;
    word-break: break-word !important;
  }
}



/* v17 force fully opaque mobile status overlay */
@media (max-width: 1024px) and (orientation: landscape) {
  #statusOverlay,
  #statusOverlay.status-overlay,
  .status-overlay,
  .status-message,
  #banner,
  .banner {
    background: rgb(20, 20, 40) !important;
    opacity: 1 !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    box-shadow: none !important;
  }

  #statusOverlay::before,
  #statusOverlay::after,
  .status-overlay::before,
  .status-overlay::after,
  .status-message::before,
  .status-message::after,
  #banner::before,
  #banner::after,
  .banner::before,
  .banner::after {
    opacity: 1 !important;
    background: transparent !important;
  }
}



/* v18: truly solid mobile status overlay */
@media (max-width: 1024px) and (orientation: landscape) {
  #statusOverlay,
  #statusOverlay.status-overlay {
    position: fixed !important;
    left: calc(var(--mobile-safe-left) + var(--mobile-rail-w) + 12px) !important;
    right: calc(var(--mobile-safe-right) + 12px) !important;
    bottom: calc(var(--mobile-safe-bottom) + 6px) !important;
    top: auto !important;
    width: auto !important;
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    padding: 10px 14px !important;
    border-radius: 12px !important;
    background: #141428 !important;
    background-image: none !important;
    opacity: 1 !important;
    color: #eef2ff !important;
    z-index: 99999 !important;
    isolation: isolate !important;
    mix-blend-mode: normal !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    overflow: hidden !important;
    border: 1px solid rgba(92,104,160,0.95) !important;
    box-shadow: 0 6px 18px rgba(0,0,0,0.35) !important;
  }

  #statusOverlay::before {
    content: "" !important;
    position: absolute !important;
    inset: 0 !important;
    background: #141428 !important;
    opacity: 1 !important;
    z-index: -1 !important;
    border-radius: inherit !important;
  }

  #statusOverlay .phase-label,
  #statusOverlay .instruction {
    position: relative !important;
    z-index: 1 !important;
    color: #eef2ff !important;
    text-shadow: none !important;
    opacity: 1 !important;
  }
}


/* v19: desktop board fill tune — expand board and keep right hero/hire info column visually matched */
@media (min-width: 1025px) {
  :root {
  --board-padding-buffer: 24px;
    --desktop-left-panel: 220px;
    --desktop-right-panel: 145px;
    --tile-gap: 6px;
    --tile-size: clamp(50px, calc((100vw - 620px) / 14), 92px);
    --board-width: calc(14 * var(--tile-size) + 13 * var(--tile-gap));
    --board-height: calc(6 * var(--tile-size) + 5 * var(--tile-gap));
  }

  .main-layout {
    gap: 14px !important;
    align-items: stretch !important;
  }

  .center-panel {
    align-items: stretch !important;
  }

  .grid,
  #grid {
    margin: 0 auto !important;
  }

  .bottom-panel {
    width: min(100%, var(--board-width)) !important;
    max-width: min(100%, var(--board-width)) !important;
  }

  .right-panel {
    min-height: calc(var(--board-height) + 20px) !important;
  }

  .selected-info,
  .abilities-panel {
    flex: 1 1 auto;
  }
}


/* v20 balance + mobile quick status */
.mobile-quick-status {
  display: none;
}

@media (max-width: 1024px) and (orientation: landscape) {
  .mobile-quick-status {
    display: grid;
    gap: 6px;
    width: var(--mobile-rail-w);
    padding: 7px 5px;
    border-radius: 12px;
    border: 1px solid rgba(145, 170, 221, 0.35);
    background: linear-gradient(180deg, rgba(18, 28, 44, 0.95), rgba(12, 20, 33, 0.95));
    box-shadow: 0 10px 20px rgba(0,0,0,0.28);
  }

  .mobile-quick-stat {
    display: grid;
    gap: 2px;
    text-align: center;
  }

  .mobile-quick-stat-label {
    font-size: 0.5rem;
