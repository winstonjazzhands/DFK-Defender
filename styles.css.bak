}

/* v12 overlay fix */
.status-message, .status-overlay {position:absolute !important; top:8px; left:50%; transform:translateX(-50%); z-index:9999; pointer-events:none; background:rgba(20,20,40,1); padding:6px 12px; border-radius:12px;}


/* v13: mobile transient banner as true overlay; no board reservation */
@media (max-width: 1024px) and (orientation: landscape) {
  #banner.banner {
    position: absolute !important;
