    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(214, 223, 241, 0.72);
  }

  .mobile-quick-stat-value {
    font-size: 0.62rem;
    font-weight: 800;
    line-height: 1.1;
    color: var(--text);
    word-break: break-word;
  }
}


/* v24.2: desktop bottom HUD split into two clean rows; keep mobile unchanged */
@media (min-width: 1025px) {
  .bottom-panel .controls-row.action-row,
  .bottom-panel .controls-row.action-row.controls-row-lean {
    display: grid;
    grid-template-columns: max-content max-content max-content minmax(132px, 1fr) minmax(92px, 0.8fr) minmax(92px, 0.8fr);
    align-items: center;
    gap: 8px;
  }

  .bottom-panel .footer-topbar,
  .bottom-panel .footer-topbar.footer-topbar-separated {
    display: contents;
  }

  .bottom-panel .footer-topbar .hud-pill {
    width: 100%;
    min-width: 0;
    padding: 8px 10px;
  }

  .bottom-panel .controls-stack {
    margin-top: 8px;
  }

  .bottom-panel .hire-section {
    width: 100%;
  }

  .bottom-panel .hire-list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 8px;
  }

  .bottom-panel .hire-list .card,
  .bottom-panel .hire-button-card {
    min-width: 0;
  }

  .bottom-panel .hire-list .card button,
  .bottom-panel .hire-button-card button {
    width: 100%;
    padding: 8px 6px;
    font-size: 0.72rem;
    line-height: 1.15;
    white-space: nowrap;
  }

  .bottom-panel .hire-list > :nth-child(1) { order: 3; }
  .bottom-panel .hire-list > :nth-child(2) { order: 2; }
  .bottom-panel .hire-list > :nth-child(3) { order: 1; }
  .bottom-panel .hire-list > :nth-child(4) { order: 5; }
  .bottom-panel .hire-list > :nth-child(5) { order: 4; }
}


/* v24.5: desktop status/info message floats near bottom center and lasts 2.5s */
@media (min-width: 1025px) {
  #statusOverlay,
  #statusOverlay.status-overlay,
  .status-overlay {
    position: fixed !important;
    left: calc(var(--desktop-left-panel) + ((100vw - var(--desktop-left-panel) - var(--desktop-right-panel)) / 2)) !important;
    right: auto !important;
    top: auto !important;
    bottom: 22px !important;
    transform: translateX(-50%) !important;
    margin: 0 !important;
    width: max-content !important;
    max-width: min(calc(var(--board-width) - 24px), calc(100vw - var(--desktop-left-panel) - var(--desktop-right-panel) - 28px)) !important;
    z-index: 1405 !important;
  }
}


/* v24.8: challenge mode visible but unavailable */
.coming-soon-toggle,
#mobileFuncChallengeBtn:disabled {
  opacity: 0.65 !important;
  filter: grayscale(0.35);
}

.coming-soon-toggle:hover,
.coming-soon-toggle:focus-visible,
#mobileFuncChallengeBtn:disabled:hover,
#mobileFuncChallengeBtn:disabled:focus-visible {
  transform: none !important;
  border-color: rgba(148, 160, 182, 0.55) !important;
  box-shadow: none !important;
}

.coming-soon-toggle,
.coming-soon-toggle.active {
  background: linear-gradient(180deg, #4f5561, #3d434e) !important;
  border-color: #8a93a3 !important;
  color: rgba(240, 244, 255, 0.92) !important;
}


/* Preparation Phase banner fix */
.preparation-phase,
.prep-phase,
.phase-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 1.15em;
  line-height: 1.4;
  padding: 10px 16px;
}

.preparation-phase span,
.prep-phase span,
.phase-banner span {
  display: inline-block;
}


.passive-card p strong {
  color: var(--text);
  font-weight: 800;
}


.wallet-auth {
  margin-top: 10px;
  padding: 10px;
  border: 1px solid rgba(102, 127, 173, 0.35);
  border-radius: 12px;
  background: rgba(14, 21, 34, 0.52);
}
.auth-fields {
  display: grid;
  gap: 6px;
  margin-top: 8px;
}
.auth-input {
  width: 100%;
  min-height: 34px;
  border-radius: 9px;
  border: 1px solid #4d5f87;
  background: rgba(10, 16, 28, 0.92);
  color: var(--text);
  padding: 0 10px;
  font-size: 0.8rem;
}
.auth-input::placeholder {
  color: var(--muted);
}
.auth-actions {
  margin-top: 8px;
}
.auth-actions-single {
  grid-template-columns: 1fr;
}
.auth-player-stats {
  margin-top: 8px;
  font-size: 0.75rem;
  line-height: 1.4;
  color: var(--text);
}
.auth-board-wrap {
  margin-top: 10px;
  padding-top: 8px;
  border-top: 1px solid rgba(102, 127, 173, 0.28);
}
.auth-board-title {
  font-size: 0.74rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #d9b679;
}
.auth-board-empty,
.auth-board-list {
  margin-top: 6px;
  font-size: 0.73rem;
  line-height: 1.4;
  color: var(--text);
}
.auth-board-list {
  display: grid;
  gap: 4px;
}
.auth-board-row {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 8px;
  align-items: center;
}
.auth-board-rank {
  color: #d9b679;
  font-weight: 800;
}
.auth-board-user {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.auth-board-score {
  font-weight: 800;
}


/* V40 leaderboard flyout */
.leaderboard-flyout-btn {
  margin-top: 6px;
  width: 100%;
  min-height: 34px;
  border-radius: 10px;
  border: 1px solid #775a31;
  background: linear-gradient(180deg, #5c4728, #47351d);
  color: #f5ead5;
  font-size: 0.82rem;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.12s ease, border-color 0.12s ease, background 0.12s ease;
}

.leaderboard-flyout-btn:hover {
  transform: translateY(-1px);
  border-color: #c59c60;
}

.leaderboard-flyout-btn:focus-visible {
  outline: 2px solid #e1bf80;
  outline-offset: 2px;
}

.leaderboard-backdrop {
  position: fixed;
  inset: 0;
  z-index: 54;
  background: rgba(3, 4, 10, 0.5);
}

.leaderboard-backdrop.hidden {
  display: none;
}

.leaderboard-flyout {
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  width: min(930px, 98vw);
  z-index: 55;
  transform: translateX(-102%);
  transition: transform 180ms ease;
  border-radius: 0 18px 18px 0;
  border-left: none;
  padding: 18px 18px 22px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(126, 43, 173, 0.18), transparent 34%),
    linear-gradient(180deg, rgba(18, 16, 34, 0.98), rgba(10, 10, 18, 0.98));
  box-shadow: 22px 0 38px rgba(0,0,0,0.45);
}

.leaderboard-flyout.open {
  transform: translateX(0);
}

.leaderboard-flyout-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 10px;
}

.leaderboard-kicker {
  color: #c6b27b;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
}

.leaderboard-title {
  margin: 4px 0 0;
  color: #f7e5b7;
  font-size: 1.75rem;
}

.leaderboard-close,
.leaderboard-sort-btn,
.leaderboard-refresh-btn {
  border: 1px solid rgba(255, 214, 102, 0.4);
  background: rgba(31, 27, 52, 0.92);
  color: #f7e5b7;
  border-radius: 10px;
}

.leaderboard-close {
  width: 38px;
  height: 38px;
  font-size: 1.5rem;
  line-height: 1;
}

.leaderboard-controls {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.leaderboard-sort-btn,
.leaderboard-refresh-btn {
  padding: 7px 11px;
  font-weight: 700;
  font-size: 0.78rem;
}

.leaderboard-sort-btn.active {
  background: linear-gradient(180deg, rgba(95, 55, 161, 0.95), rgba(51, 32, 93, 0.95));
  box-shadow: inset 0 0 0 1px rgba(255, 214, 102, 0.16);
}

.leaderboard-status {
  min-height: 0;
  margin-bottom: 0;
  color: #d3d5df;
  font-size: 0.82rem;
}

.leaderboard-status:empty {
  display: none;
}

.leaderboard-status.error {
  color: #ff9d9d;
}

.leaderboard-table-wrap {
  position: relative;
  z-index: 1;
  max-height: none;
  min-height: 0;
  flex: 1 1 auto;
  overflow: hidden;
  scrollbar-width: none;
  border-radius: 14px;
  border: 1px solid rgba(255, 214, 102, 0.18);
  background: rgba(10, 12, 22, 0.78);
}

.leaderboard-table {
  width: 100%;
  min-width: 0;
  border-collapse: collapse;
  table-layout: fixed;
}

.leaderboard-table-wrap::-webkit-scrollbar {
  display: none;
}

.leaderboard-table th,
.leaderboard-table td {
  padding: 7px 10px;
  text-align: left;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  color: #eef1f8;
  font-size: 0.74rem;
}

.leaderboard-table thead th {
  position: sticky;
  top: 0;
  z-index: 2;
  background: rgba(26, 20, 43, 0.98);
  color: #f7e5b7;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: 0.6rem;
}

.leaderboard-table tbody tr:nth-child(odd) {
  background: rgba(255, 255, 255, 0.025);
}

.leaderboard-table tbody tr:hover {
  background: rgba(255, 214, 102, 0.08);
}

.leaderboard-rank {
  width: 40px;
  color: #ffd666;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}

.leaderboard-name-cell {
  max-width: 0;
  font-weight: 700;
}

.leaderboard-empty {
  text-align: center !important;
  color: #cfd4e2;
}

.leaderboard-wallet-cell {
  color: #c9d0e6;
  font-variant-numeric: tabular-nums;
}

.leaderboard-wave-cell,
.leaderboard-runs-cell,
.leaderboard-burn-cell {
  text-align: right;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

.leaderboard-lurker {
  position: absolute;
  right: -10px;
  bottom: 14px;
  width: 96px;
  height: auto;
  opacity: 0.72;
  filter: drop-shadow(0 10px 18px rgba(0,0,0,0.5));
  pointer-events: none;
  z-index: 0;
}

body.leaderboard-open {
  overflow: hidden;
}

@media (max-width: 900px) {
  .leaderboard-flyout-btn {
    left: 8px;
    top: auto;
    bottom: 96px;
    transform: none;
  }

  .leaderboard-flyout {
    width: min(420px, 94vw);
  }
}


.leaderboard-flyout.leaderboard-flyout-wide {
  width: min(1240px, 98vw);
}

.leaderboard-table th:nth-child(1),
.leaderboard-table td:nth-child(1) {
  width: 48px;
}

.leaderboard-table th:nth-child(2),
.leaderboard-table td:nth-child(2) {
  width: 320px;
}

.leaderboard-table th:nth-child(3),
.leaderboard-table td:nth-child(3) {
  width: 126px;
}

.leaderboard-table th:nth-child(4),
.leaderboard-table td:nth-child(4),
.leaderboard-table th:nth-child(5),
.leaderboard-table td:nth-child(5) {
  width: 86px;
}

.leaderboard-table th:nth-child(6),
.leaderboard-table td:nth-child(6) {
  width: 112px;
}

.leaderboard-name-cell,
.leaderboard-wallet-cell {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}


.leaderboard-table th:nth-child(4),
.leaderboard-table th:nth-child(5),
.leaderboard-table th:nth-child(6),
.leaderboard-table td:nth-child(4),
.leaderboard-table td:nth-child(5),
.leaderboard-table td:nth-child(6) {
  text-align: right;
}

.leaderboard-table th:nth-child(3),
.leaderboard-table td:nth-child(3) {
  padding-left: 4px;
}

@media (max-width: 900px) {
  .leaderboard-flyout {
    width: min(96vw, 560px);
  }

  .leaderboard-flyout.leaderboard-flyout-wide {
    width: min(97vw, 640px);
  }
}


.statue-hp-bar {
  left: 4% !important;
  width: 92% !important;
  bottom: 12px !important;
  height: 8px !important;
  border: 1px solid rgba(255,255,255,0.6);
  box-shadow: 0 0 8px rgba(255,255,255,0.22);
}


/* V45.6 bounty board */
.bounty-toggle {
  margin-top: 8px;
}

.bounty-modal-card {
  max-width: min(920px, calc(100vw - 40px));
}

.bounty-body {
  display: grid;
  gap: 16px;
}

.bounty-hero-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 14px 16px;
  border-radius: 16px;
  border: 1px solid rgba(224, 188, 117, 0.28);
  background: linear-gradient(180deg, rgba(52, 34, 14, 0.95), rgba(26, 19, 9, 0.96));
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03), 0 14px 30px rgba(0,0,0,0.22);
}

.bounty-strip-kicker {
  color: #e2bd7c;
  font-size: 12px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 6px;
}

.bounty-strip-copy {
  margin: 0;
  color: #efe8d6;
  line-height: 1.55;
}

.bounty-strip-badge {
  flex: 0 0 auto;
  padding: 10px 12px;
  border-radius: 999px;
  background: rgba(230, 191, 105, 0.12);
  border: 1px solid rgba(230, 191, 105, 0.35);
  color: #f2d79a;
  font-weight: 800;
  white-space: nowrap;
}

.bounty-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.bounty-card {
  position: relative;
  overflow: hidden;
  padding: 16px;
  border-radius: 18px;
  border: 1px solid rgba(188, 154, 88, 0.24);
  background: linear-gradient(180deg, rgba(34, 24, 14, 0.98), rgba(18, 13, 7, 0.98));
  box-shadow: 0 12px 26px rgba(0,0,0,0.24);
  min-height: 188px;
}

.bounty-card::after {
  content: '';
  position: absolute;
  inset: auto -40px -60px auto;
  width: 150px;
  height: 150px;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(227, 190, 109, 0.12), rgba(227, 190, 109, 0));
  pointer-events: none;
}

.bounty-card.is-open {
  border-color: rgba(223, 187, 105, 0.5);
  background: linear-gradient(180deg, rgba(52, 34, 14, 0.98), rgba(24, 18, 9, 0.98));
}

.bounty-card-top,
.bounty-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.bounty-tier-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
}

.bounty-tier-label {
  color: #ebd4a4;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.bounty-tier-index {
  width: 34px;
  height: 34px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  color: #fff5dc;
  font-weight: 900;
}

.bounty-reward-pill,
.bounty-state-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 7px 11px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.04em;
}

.bounty-reward-pill.is-open,
.bounty-state-chip.is-open {
  background: rgba(244, 201, 109, 0.14);
  border: 1px solid rgba(244, 201, 109, 0.42);
  color: #ffd986;
}

.bounty-reward-pill.is-locked,
.bounty-state-chip.is-locked {
  background: rgba(157, 168, 191, 0.1);
  border: 1px solid rgba(157, 168, 191, 0.26);
  color: #cfd5e1;
}

.bounty-card-title {
  margin: 16px 0 10px;
  color: #fff2cf;
  font-size: 21px;
  line-height: 1.2;
}

.bounty-card-copy {
  margin: 0 0 16px;
  color: #ece2ca;
  line-height: 1.6;
}

.bounty-chain-note {
  color: #b3bdcf;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.bounty-card.is-claimed {
  border-color: rgba(108, 189, 128, 0.42);
  background: linear-gradient(180deg, rgba(18, 46, 26, 0.98), rgba(11, 28, 16, 0.98));
}

.bounty-reward-pill.is-claimed,
.bounty-state-chip.is-claimed {
  background: rgba(108, 189, 128, 0.14);
  border: 1px solid rgba(108, 189, 128, 0.42);
  color: #b8f0c6;
}

.bounty-claimant {
  margin-top: 12px;
  color: #d8e8cf;
  font-size: 13px;
}

.bounty-claim-btn {
  margin-top: 14px;
  width: 100%;
  border: 1px solid rgba(233, 198, 124, 0.36);
  border-radius: 12px;
  padding: 12px 14px;
  background: linear-gradient(180deg, rgba(96, 62, 24, 0.98), rgba(64, 40, 15, 0.98));
  color: #fff2cf;
  font-size: 14px;
  font-weight: 800;
  letter-spacing: 0.04em;
  cursor: pointer;
}

.bounty-claim-btn:disabled {
  cursor: not-allowed;
  opacity: 0.5;
}

.bounty-status-banner {
  padding: 12px 14px;
  border-radius: 14px;
  background: rgba(230, 191, 105, 0.1);
  border: 1px solid rgba(230, 191, 105, 0.24);
  color: #f5e1b2;
}

.bounty-status-banner.is-error {
  background: rgba(179, 74, 74, 0.14);
  border-color: rgba(179, 74, 74, 0.32);
  color: #ffd4d4;
}

@media (max-width: 900px) {
  .bounty-grid {
    grid-template-columns: 1fr;
  }
  .bounty-hero-strip {
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 1024px) and (orientation: landscape) {
  .bounty-modal-card {
    max-width: min(94vw, 860px);
  }
}


/* V46.3 elite waves + relic codex */
.known-relics-toggle { margin-top: 8px; }
.known-relics-modal-card { max-width: min(920px, calc(100vw - 40px)); }
.known-relics-body { display: grid; gap: 16px; }
.known-relic-section { display: grid; gap: 12px; }
.known-relic-heading { font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; }
.known-relic-heading-found { color: #f6db9b; }
.known-relic-found-list { display: flex; flex-wrap: wrap; gap: 8px; }
.known-relic-found-empty { color: var(--muted); }
.known-relic-card { padding: 14px 16px; border-radius: 14px; border: 1px solid rgba(255,255,255,0.12); background: rgba(15,18,28,0.88); }
.known-relic-card h4 { margin: 0 0 6px; }
.known-relic-card p { margin: 0; line-height: 1.55; }
.relic-choice-card { position: relative; }
.relic-choice-rarity { display: inline-block; margin-bottom: 8px; font-size: 11px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
.relic-rarity-common { color: #b8bec8; border-color: rgba(184,190,200,0.28); }
.relic-rarity-rare { color: #79b8ff; border-color: rgba(121,184,255,0.3); }
.relic-rarity-legendary { color: #ffb261; border-color: rgba(255,178,97,0.36); }
.relic-rarity-mythic { color: #d06dff; border-color: rgba(208,109,255,0.42); }
.relic-choice-card.relic-rarity-common, .known-relic-card.relic-rarity-common, .relic-pill.relic-rarity-common { box-shadow: inset 0 0 0 1px rgba(184,190,200,0.18); }
.relic-choice-card.relic-rarity-rare, .known-relic-card.relic-rarity-rare, .relic-pill.relic-rarity-rare { box-shadow: inset 0 0 0 1px rgba(121,184,255,0.22); }
.relic-choice-card.relic-rarity-legendary, .known-relic-card.relic-rarity-legendary, .relic-pill.relic-rarity-legendary { box-shadow: inset 0 0 0 1px rgba(255,178,97,0.24); }
.relic-choice-card.relic-rarity-mythic, .known-relic-card.relic-rarity-mythic, .relic-pill.relic-rarity-mythic { box-shadow: inset 0 0 0 1px rgba(208,109,255,0.26); }
.relic-hidden-card { text-align: center; }
.elite-wave-modal-card { max-width: min(640px, calc(100vw - 40px)); border-color: rgba(255,140,92,0.45); box-shadow: 0 20px 48px rgba(0,0,0,0.32), inset 0 0 0 1px rgba(255,255,255,0.04); }
.elite-wave-body { display: grid; gap: 12px; text-align: center; }
.elite-wave-kicker { color: #ffb580; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
.elite-wave-title { margin: 0; color: #fff2d8; font-size: 26px; }
.elite-wave-copy { margin: 0; color: #efe5d6; }
.elite-wave-summary { padding: 14px 16px; border-radius: 14px; background: rgba(255,145,87,0.1); border: 1px solid rgba(255,145,87,0.25); color: #ffe3c3; line-height: 1.6; }
body.elite-wave-shake .elite-wave-modal-card { animation: eliteWaveShake 0.5s ease-in-out; }
@keyframes eliteWaveShake { 0%,100% { transform: translateX(0); } 20% { transform: translateX(-8px); } 40% { transform: translateX(8px); } 60% { transform: translateX(-6px); } 80% { transform: translateX(6px); } }


.tracked-runs-toggle {
  margin-top: 8px;
}

.tracked-runs-modal-card {
  max-width: min(780px, calc(100vw - 40px));
}

.tracked-runs-body {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.tracked-runs-hero-strip {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  padding: 16px 18px;
  border-radius: 18px;
  background: linear-gradient(180deg, rgba(12,20,34,0.94), rgba(8,14,24,0.9));
  border: 1px solid rgba(124, 154, 255, 0.18);
}

.tracked-runs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 12px;
}
.tracked-runs-note {
  margin: 10px 0 0;
  color: #c6d3ff;
  font-size: 0.92rem;
}

.tracked-runs-search-wrap {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.tracked-runs-search-label {
  color: rgba(210, 220, 255, 0.82);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.tracked-runs-search-input {
  width: 100%;
  min-height: 40px;
  border-radius: 12px;
  border: 1px solid rgba(124, 154, 255, 0.26);
  background: rgba(8, 14, 24, 0.92);
  color: #f3f5ff;
  padding: 0 12px;
  font-size: 0.95rem;
}

.tracked-runs-search-input::placeholder {
  color: rgba(211, 219, 255, 0.42);
}

.tracked-runs-search-input:focus-visible {
  outline: 2px solid rgba(160, 183, 255, 0.55);
  outline-offset: 2px;
}


.tracked-run-card {
  padding: 14px 16px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(8, 12, 20, 0.88);
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.tracked-run-card.is-used {
  border-color: rgba(55, 212, 125, 0.48);
  box-shadow: inset 0 0 0 1px rgba(55, 212, 125, 0.15);
  background: linear-gradient(180deg, rgba(11, 36, 21, 0.92), rgba(7, 24, 15, 0.9));
}

.tracked-run-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.tracked-run-label {
  font-size: 0.82rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(204, 214, 255, 0.76);
}

.tracked-run-id {
  margin-top: 4px;
  font-size: 0.92rem;
  color: rgba(255,255,255,0.76);
}

.tracked-run-wave {
  font-size: 1.2rem;
  font-weight: 700;
  color: #f7f3dd;
  white-space: nowrap;
}

.tracked-run-status {
  display: inline-flex;
  align-self: flex-start;
  padding: 6px 10px;
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.tracked-run-status.is-used {
  color: #67e59a;
  background: rgba(38, 157, 86, 0.22);
}

.tracked-run-status.is-available {
  color: #d9deff;
  background: rgba(117, 132, 202, 0.18);
}

@media (max-width: 900px) {
  .tracked-runs-hero-strip {
    flex-direction: column;
  }

  .tracked-runs-modal-card {
    max-width: min(100vw - 20px, 720px);
  }
}


.quests-toggle { margin-top: 8px; }
.quests-modal-card { max-width: min(920px, calc(100vw - 40px)); }
.quests-body { display: grid; gap: 16px; }
.quest-progress-row { display: grid; gap: 8px; margin-bottom: 12px; }
.quest-progress-track { position: relative; height: 10px; border-radius: 999px; background: rgba(255,255,255,0.08); overflow: hidden; border: 1px solid rgba(255,255,255,0.08); }
.quest-progress-track span { display: block; height: 100%; border-radius: 999px; background: linear-gradient(90deg, rgba(102,184,255,0.95), rgba(138,240,196,0.95)); }
.quest-progress-text { color: #d9e7ff; font-size: 12px; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; }
.quest-card { min-height: 220px; }
.quests-summary-strip { border-color: rgba(102, 184, 255, 0.22); background: linear-gradient(180deg, rgba(10, 24, 40, 0.94), rgba(7, 16, 28, 0.92)); }
@media (max-width: 1024px) and (orientation: landscape) { .quests-modal-card { max-width: min(94vw, 860px); } }


.desktop-only-inline { display: inline-flex; }
@media (max-width: 900px) { .desktop-only-inline { display: none !important; } }

@media (min-width: 1025px) {
  #infoPanel { padding: 10px; }
  #infoPanel .panel-toggle-btn,
  #infoPanel .action-group button,
  #infoPanel .abilities-panel button {
    font-size: 0.74rem;
    padding: 7px 8px;
  }
  #infoPanel .selected-info {
    font-size: 0.78rem;
    line-height: 1.35;
    padding: 8px;
  }
}


/* v46.9.1.60: keep the selected info box height fixed, but give the desktop info panel 50% more vertical room so all action buttons stay visible */
@media (min-width: 1025px) {
  :root {
  --board-padding-buffer: 24px;
    --desktop-right-panel: 270px;
  }

  .right-panel {
    min-height: 540px;
    height: 540px;
    max-height: 540px;
  }

  .selected-info {
    min-height: 74px;
    max-height: 74px;
  }
}

.version-badge {
  position: fixed;
  right: 10px;
  bottom: 8px;
  z-index: 120;
  padding: 4px 8px;
  border-radius: 999px;
  background: rgba(8, 16, 28, 0.78);
  border: 1px solid rgba(183, 216, 255, 0.24);
  color: rgba(232, 243, 255, 0.86);
  font-size: 11px;
  letter-spacing: 0.06em;
  pointer-events: none;
  backdrop-filter: blur(4px);
}

@media (max-width: 900px) {
  .version-badge {
    right: 8px;
    bottom: 72px;
    font-size: 10px;
  }
}


/* v46.9.1.27 desktop width restore + announcement modal */
@media (min-width: 1025px) {
  :root {
  --board-padding-buffer: 24px;
    --desktop-left-panel: 300px;
    --desktop-right-panel: 270px;
  }
  .main-layout {
    grid-template-columns: var(--desktop-left-panel) minmax(0, 1fr) var(--desktop-right-panel) !important;
  }
}

.intro-body p:last-child { margin-bottom: 0; }

.story-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}
.story-overlay.hidden { display: none; }

.story-text {
  --story-frame-duration: 6500ms;
  max-width: 980px;
  color: #f2ece1;
  font-size: 1.9rem;
  line-height: 1.72;
  text-align: center;
  opacity: 0;
  transform: scale(1);
  transform-origin: center center;
  font-family: 'Cinzel', Georgia, serif;
  font-weight: 700;
  letter-spacing: 0.02em;
  text-shadow:
    0 2px 0 rgba(0,0,0,0.55),
    0 0 18px rgba(0,0,0,0.32);
  padding: 32px 44px;
  will-change: transform, opacity;
}
.story-text.visible {
  animation: storyTextZoom var(--story-frame-duration) linear forwards;
}

.story-text.story-text-staggered {
  max-width: 1400px;
  white-space: nowrap;
}

.story-text.story-text-staggered .story-segment {
  display: inline-block;
  opacity: 0;
}

.story-text.story-text-staggered.visible .story-segment-a {
  animation: storySegmentFadeIn 500ms ease forwards;
}

.story-text.story-text-staggered.visible .story-segment-b {
  margin-left: 0.35em;
  animation: storySegmentFadeIn 500ms ease forwards 2000ms;
}

@keyframes storySegmentFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}


@keyframes storyTextZoom {
  0% {
    opacity: 0;
    transform: scale(1);
  }
  12% {
    opacity: 1;
    transform: scale(1.015);
  }
  82% {
    opacity: 1;
    transform: scale(1.085);
  }
  100% {
    opacity: 0;
    transform: scale(1.14);
  }
}


.story-skip-btn {
  border: 1px solid rgba(255,255,255,0.28);
  background: rgba(10,10,10,0.55);
  color: #f2f2f2;
  padding: 8px 14px;
  border-radius: 10px;
  font-size: 0.95rem;
  cursor: pointer;
  backdrop-filter: blur(4px);
}
.story-skip-btn:hover {
  background: rgba(20,20,20,0.78);
  border-color: rgba(255,255,255,0.42);
}

.story-controls {
  position: absolute;
  top: 18px;
  right: 18px;
  z-index: 2001;
  display: flex;
  align-items: center;
  gap: 10px;
}

.story-volume-wrap {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1px solid rgba(255,255,255,0.28);
  background: rgba(10,10,10,0.55);
  color: #f2f2f2;
  padding: 8px 12px;
  border-radius: 10px;
  font-size: 0.95rem;
  backdrop-filter: blur(4px);
}

.story-volume-label,
.story-volume-value {
  font-weight: 700;
  white-space: nowrap;
}

.story-volume-slider {
  width: 130px;
  accent-color: #8b7cff;
}

.story-mute-btn {
  white-space: nowrap;
}

@media (max-width: 900px) {
  .story-controls {
    left: 12px;
    right: 12px;
    top: 12px;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .story-volume-wrap {
    order: 3;
    width: 100%;
    justify-content: space-between;
  }

  .story-volume-slider {
    flex: 1 1 auto;
    min-width: 120px;
  }
}


/* Dark Summoner presence dim */
.board-dim {
  filter: brightness(0.9);
  transition: filter 300ms ease;
}


.wallet-hero-bonus-section{
  margin-top:12px;
  padding-top:10px;
  border-top:1px solid rgba(255,255,255,0.08);
}
.wallet-hero-bonus-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  margin-bottom:8px;
}
.wallet-hero-bonus-title{
  font-size:0.95rem;
  font-weight:800;
  letter-spacing:0.04em;
  text-transform:uppercase;
  color:#f4e6bd;
}
.wallet-hero-refresh-btn{
  padding:6px 10px;
  font-size:0.82rem;
}
.wallet-hero-bonus-body{
  display:grid;
  gap:8px;
}
.wallet-hero-slot-group{
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(255,255,255,0.06);
  border-radius:10px;
  padding:8px;
}
.wallet-hero-slot-heading{
  font-size:0.86rem;
  font-weight:800;
  margin-bottom:6px;
  color:#f0ede0;
}
.wallet-hero-card-list{
  display:grid;
  gap:6px;
}
.wallet-hero-card{
  display:grid;
  grid-template-columns:44px 1fr auto;
  align-items:center;
  gap:8px;
  width:100%;
  text-align:left;
  padding:6px 8px;
  border-radius:10px;
  border:1px solid rgba(255,255,255,0.08);
  background:rgba(18,18,22,0.72);
  color:#ececec;
  cursor:pointer;
}
.wallet-hero-card img{
  width:44px;
  height:44px;
  object-fit:contain;
  object-position:center center;
  border-radius:8px;
  background:rgba(255,255,255,0.05);
}
.wallet-hero-card.is-selected{
  border-color:rgba(244,230,189,0.72);
  box-shadow:0 0 0 1px rgba(244,230,189,0.22) inset;
  background:rgba(56,46,18,0.45);
}
.wallet-hero-card-meta{
  display:flex;
  flex-direction:column;
  gap:2px;
}
.wallet-hero-card-title{
  font-size:0.87rem;
  font-weight:700;
}
.wallet-hero-card-sub{
  font-size:0.76rem;
  opacity:0.78;
}
.wallet-hero-card-badge{
  font-size:0.74rem;
  font-weight:800;
  color:#f4e6bd;
}
.wallet-hero-empty{
  font-size:0.78rem;
  opacity:0.72;
}


.wallet-hero-slot-toggle{
  width:100%;
  display:grid;
  grid-template-columns:1fr auto auto;
  gap:8px;
  align-items:center;
  padding:0;
  background:transparent;
  border:0;
  color:inherit;
  cursor:pointer;
  text-align:left;
}
.wallet-hero-slot-summary{
  font-size:0.72rem;
  opacity:0.76;
  font-weight:600;
}
.wallet-hero-slot-chevron{
  font-size:1rem;
  opacity:0.8;
}
.wallet-hero-slot-panel{
  display:none;
  margin-top:8px;
}
.wallet-hero-slot-panel.is-open{
  display:block;
}
.wallet-hero-search-wrap{
  margin-bottom:8px;
}
.wallet-hero-search-input{
  width:100%;
  padding:8px 10px;
  border-radius:9px;
  border:1px solid rgba(255,255,255,0.08);
  background:rgba(14,14,18,0.7);
  color:#ececec;
  font-size:0.8rem;
}
.wallet-hero-search-input::placeholder{
  color:rgba(255,255,255,0.42);
}


.wallet-hero-image-fallback {
  object-fit: contain;
  background: rgba(19, 23, 37, 0.72);
}
.wallet-hero-selected-wrap{
  margin-bottom:8px;
}
.wallet-hero-selected-label{
  font-size:0.72rem;
  font-weight:800;
  letter-spacing:0.04em;
  text-transform:uppercase;
  color:#f4e6bd;
  margin-bottom:6px;
}
.wallet-hero-selected-card{
  display:grid;
  grid-template-columns:52px 1fr;
  gap:10px;
  align-items:center;
  padding:8px 10px;
  border-radius:10px;
  border:1px solid rgba(244,230,189,0.18);
  background:rgba(56,46,18,0.28);
}
.wallet-hero-selected-card img{
  width:52px;
  height:52px;
  object-fit:contain;
  object-position:center center;
  border-radius:8px;
  background:rgba(255,255,255,0.05);
}
.wallet-hero-selected-meta{
  display:flex;
  flex-direction:column;
  gap:3px;
}
.wallet-hero-selected-title{
  font-size:0.88rem;
  font-weight:800;
  color:#f7f0d8;
}
.wallet-hero-selected-sub{
  font-size:0.76rem;
  opacity:0.82;
}




/* v46.9.1.52 intro final-frame hold */
#storyText.story-one-line,
.story-text.story-one-line {
  white-space: nowrap !important;
  max-width: none !important;
  width: max-content !important;
  overflow-wrap: normal !important;
  word-break: normal !important;
  margin-left: auto !important;
  margin-right: auto !important;
}

#storyText,
.story-text {
  overflow-wrap: break-word;
}

/* Frame 8 big title */
#storyText.big-final,
.story-text.big-final {
  white-space: nowrap !important;
  max-width: none !important;
  width: max-content !important;
  overflow-wrap: normal !important;
  word-break: normal !important;
  margin-left: auto !important;
  margin-right: auto !important;
  font-size: clamp(96px, 9vw, 144px) !important;
  font-weight: 900 !important;
  letter-spacing: 0.06em;
  line-height: 1;
  text-shadow:
    0 0 10px rgba(255, 245, 214, 0.22),
    0 0 22px rgba(255, 245, 214, 0.16),
    0 2px 0 rgba(0, 0, 0, 0.65),
    0 0 30px rgba(0, 0, 0, 0.28);
}


.wallet-hero-panel .wallet-hero-panel-body{display:block;}
.wallet-hero-panel.collapsed .wallet-hero-panel-body{display:none;}
.wallet-hero-panel-toggle{width:100%;}
.wallet-hero-panel-summary{font-size:0.72rem; opacity:0.82; margin-left:auto; margin-right:10px;}
.wallet-hero-panel-body{padding-top:8px;}
.wallet-hero-bonus-header{justify-content:flex-end;}
.leaderboard-nft-cell{font-weight:700; text-align:center;}
.leaderboard-nft-cell.is-yes{color:#8fe0a2;}
.leaderboard-nft-cell.is-no{color:#d9c4a1; opacity:0.92;}
.leaderboard-table th:nth-child(7),
.leaderboard-table td:nth-child(7){
  width: 86px;
  text-align:center;
  white-space:nowrap;
}

.burned-gold-block {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.burned-gold-leader-display {
  font-size: 0.72rem;
  color: rgba(232, 221, 189, 0.88);
  line-height: 1.25;
}


/* v46.9.1.60 user fix: taller desktop info panel, dark summoner foot-cloud, smaller boss, smaller skitter explosion */
.boss-storm-cloud {
  position: absolute;
  pointer-events: none;
  z-index: 5;
  overflow: visible;
  filter: blur(2px);
}
.boss-storm-cloud-blob {
  position: absolute;
  border-radius: 999px;
  background:
    radial-gradient(circle at 50% 50%, rgba(34, 30, 52, 0.9) 0%, rgba(23, 20, 36, 0.82) 48%, rgba(8, 8, 14, 0.18) 74%, rgba(8, 8, 14, 0) 100%);
  opacity: 0.82;
  transform: translate(-50%, -50%);
  animation: bossStormCloudDrift ease-in-out infinite;
}
@keyframes bossStormCloudDrift {
  0% { transform: translate(-50%, -50%) scale(0.94); opacity: 0.74; }
  25% { transform: translate(-46%, -58%) scale(1.02); opacity: 0.88; }
  50% { transform: translate(-54%, -47%) scale(1.08); opacity: 0.8; }
  75% { transform: translate(-48%, -54%) scale(0.98); opacity: 0.9; }
  100% { transform: translate(-50%, -50%) scale(0.94); opacity: 0.74; }
}
@media (min-width: 1025px) {
  :root {
  --board-padding-buffer: 24px;
    --desktop-right-panel: 270px;
  }
  .right-panel {
    min-height: 891px !important;
    height: 891px !important;
    max-height: 891px !important;
  }
}


/* DFK Gold swap + relic modal layout hardening */
.relic-modal-card {
  width: min(1360px, calc(100vw - 32px));
  max-width: min(1360px, calc(100vw - 32px));
  overflow-x: hidden;
  overflow-y: auto;
}
.relic-list {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
  align-items: stretch;
  width: 100%;
  max-width: 100%;
}
.relic-list > * {
  min-width: 0;
}
.relic-list > .relic-skip-btn {
  grid-column: 1 / -1;
  justify-self: stretch;
  width: 100%;
}
.dfkgold-swap-card {
  min-height: 100%;
}
@media (max-width: 1200px) {
  .relic-modal-card {
    width: min(1080px, calc(100vw - 24px));
    max-width: min(1080px, calc(100vw - 24px));
  }
  .relic-list {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}
@media (max-width: 900px) {
  .relic-modal-card {
    width: min(760px, calc(100vw - 20px));
    max-width: min(760px, calc(100vw - 20px));
  }
  .relic-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
@media (max-width: 640px) {
  .relic-list {
    grid-template-columns: 1fr;
  }
}


.transfer-heroes-toggle { margin-top: 8px; }
.transfer-heroes-modal {
  position: fixed;
  inset: 0;
  z-index: 90;
  background: rgba(5, 8, 22, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.transfer-heroes-modal.hidden { display: none; }
.transfer-heroes-modal-card {
  width: min(1320px, calc(100vw - 36px));
  max-height: min(90vh, 960px);
  display: flex;
  flex-direction: column;
  gap: 14px;
  overflow: hidden;
}
.transfer-heroes-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
.transfer-heroes-controls { display: grid; grid-template-columns: minmax(280px, 1.35fr) minmax(240px, 1fr) minmax(200px, .8fr); gap: 12px; align-items: end; }
.transfer-heroes-field { display: flex; flex-direction: column; gap: 6px; font-size: 12px; color: #d4dcff; min-width: 0; }
.transfer-heroes-input { width: 100%; border-radius: 10px; border: 1px solid rgba(122,138,208,.45); background: #12193e; color: #fff; padding: 10px 12px; min-height: 42px; }
.transfer-heroes-select { appearance: none; }
.transfer-heroes-input:focus-visible { outline: 2px solid rgba(132,145,255,.7); outline-offset: 1px; }
.transfer-heroes-toolbar { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.transfer-heroes-summary { color: #cfd8ff; font-size: 12px; margin-left: auto; }
.transfer-heroes-status { margin: 0; }
.transfer-heroes-pagination { display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 2px; }
.transfer-heroes-page-label { min-width: 110px; text-align: center; color: #dbe3ff; font-size: 12px; font-weight: 700; }
.transfer-heroes-body { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; overflow: auto; padding-right: 4px; min-height: 260px; align-content: start; }
.transfer-heroes-empty { border: 1px dashed rgba(130,145,220,.4); border-radius: 14px; padding: 18px; color: #dbe1ff; background: rgba(15,20,50,.55); }
.transfer-hero-card { display: grid; grid-template-columns: 84px minmax(0, 1fr); align-items: center; gap: 12px; width: 100%; text-align: left; border: 1px solid rgba(120,136,210,.35); border-radius: 14px; padding: 10px; background: rgba(18,25,62,.92); color: #fff; cursor: pointer; min-height: 106px; }
.transfer-hero-card:hover { border-color: rgba(162,177,255,.7); transform: translateY(-1px); }
.transfer-hero-card.is-selected { border-color: #f1cf49; box-shadow: 0 0 0 1px rgba(241,207,73,.45) inset; }
.transfer-hero-card-art-wrap { width: 84px; height: 84px; border-radius: 12px; overflow: hidden; background: #0d122f; border: 1px solid rgba(120,136,210,.25); display: flex; align-items: center; justify-content: center; }
.transfer-hero-card img { width: 100%; height: 100%; object-fit: cover; background: #0d122f; flex: none; }
.transfer-hero-card-meta { display: flex; flex-direction: column; gap: 5px; min-width: 0; }
.transfer-hero-card-topline { display: flex; align-items: flex-start; gap: 8px; }
.transfer-hero-card-title { font-weight: 700; min-width: 0; }
.transfer-hero-card-sub { color: #ced7ff; font-size: 12px; line-height: 1.25; }
.transfer-hero-card-badge { margin-left: auto; align-self: flex-start; font-size: 11px; font-weight: 700; color: #f3dc75; white-space: nowrap; }
.transfer-heroes-footer { display: flex; justify-content: flex-end; }
@media (max-width: 1180px) { .transfer-heroes-body { grid-template-columns: repeat(3, minmax(0,1fr)); } .transfer-heroes-controls { grid-template-columns: 1fr 1fr; } .transfer-heroes-field-sort { grid-column: span 2; } }
@media (max-width: 980px) { .transfer-heroes-body { grid-template-columns: repeat(2, minmax(0,1fr)); } .transfer-heroes-controls { grid-template-columns: 1fr; } .transfer-heroes-field-sort { grid-column: auto; } }
@media (max-width: 640px) { .transfer-heroes-modal { padding: 10px; } .transfer-heroes-modal-card { width: calc(100vw - 20px); max-height: 92vh; } .transfer-heroes-body { grid-template-columns: 1fr; } .transfer-hero-card { grid-template-columns: 72px minmax(0,1fr); min-height: 94px; } .transfer-hero-card-art-wrap { width: 72px; height: 72px; } }


.burned-gold-display {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.45rem 0.8rem;
  border-radius: 999px;
  border: 1px solid rgba(255, 214, 102, 0.4);
  background: rgba(36, 26, 10, 0.72);
  color: #ffd666;
  font-weight: 700;
  font-size: 0.9rem;
  line-height: 1;
  white-space: nowrap;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.04);
}

.panel-toggle-row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-wrap: wrap;
}


.milestone-hero-offer-card {
  max-width: 920px;
}

.milestone-hero-offer-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  justify-content: center;
  padding: 0 22px 20px;
}

.milestone-hero-offer-btn {
  min-width: 140px;
}

.milestone-hero-offer-note {
  width: 100%;
  text-align: center;
  color: rgba(220, 227, 239, 0.82);
  font-size: 13px;
  line-height: 1.45;
  padding-top: 2px;
}

@media (max-width: 760px) {
  .milestone-hero-offer-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .milestone-hero-offer-btn {
    width: 100%;
  }
}

/* ===== desktop board fill fix ===== */
@media (min-width: 1025px) {
  :root {
  --board-padding-buffer: 24px;
    --desktop-shell-pad: 24px;
    --desktop-gap: 12px;
    --desktop-left-panel: clamp(180px, 16vw, 248px);
    --desktop-right-panel: clamp(190px, 16.5vw, 248px);
    --desktop-board-min-tile: 34px;
    --desktop-board-max-tile: 110px;
    --tile-gap: clamp(3px, 0.35vw, 6px);
    --desktop-board-fit-width: calc(
      (
        100vw
        - var(--desktop-shell-pad)
        - var(--desktop-left-panel)
        - var(--desktop-right-panel)
        - (2 * var(--desktop-gap))
        - (13 * var(--tile-gap))
      ) / 14
    );
    --tile-size: clamp(
      var(--desktop-board-min-tile),
      var(--desktop-board-fit-width),
      var(--desktop-board-max-tile)
    );
    --board-width: calc(14 * var(--tile-size) + 13 * var(--tile-gap));
    --board-height: calc(6 * var(--tile-size) + 5 * var(--tile-gap));
  }

  #app {
    padding: 12px;
  }

  .main-layout {
    display: grid !important;
    grid-template-columns:
      minmax(52px, var(--desktop-left-panel))
      minmax(0, 1fr)
      minmax(52px, var(--desktop-right-panel));
    gap: var(--desktop-gap) !important;
    align-items: start;
  }

  .center-panel {
    width: 100%;
    align-items: center;
  }

  .grid,
  #grid.grid {
    width: var(--board-width) !important;
    max-width: 100% !important;
    grid-template-columns: repeat(14, var(--tile-size)) !important;
    grid-template-rows: repeat(6, var(--tile-size)) !important;
    justify-content: center;
    margin-left: auto;
    margin-right: auto;
  }

  .bottom-panel {
    width: min(100%, var(--board-width));
    max-width: min(100%, var(--board-width));
  }

  .left-panel,
  .right-panel {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    font-size: clamp(13px, 0.72vw, 16px);
  }

  body.runlog-collapsed {
    --desktop-left-panel: 52px;
  }

  body.info-collapsed {
    --desktop-right-panel: 52px;
  }
}
