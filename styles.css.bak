/* === FINAL DESKTOP BOARD SAFETY LAYOUT OVERRIDES === */
.runlog-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  margin-bottom:10px;
}
.runlog-header h2{ margin:0; }
.runlog-inline-toggle{
  display:none;
  width:26px;
  height:26px;
  align-items:center;
  justify-content:center;
  border:1px solid #3a4b70;
  border-radius:8px;
  background:rgba(82,95,145,0.28);
  color:var(--text);
  cursor:pointer;
  font-size:16px;
  font-weight:900;
  line-height:1;
  flex:0 0 auto;
}
.runlog-inline-toggle:hover{ background:rgba(98,112,170,0.42); }

@media (min-width: 901px){
  :root{
    --desktop-left-panel: 300px;
    --desktop-right-panel: 270px;
    --desktop-shell-pad: 32px;
    --desktop-grid-gaps: 24px;
    --desktop-board-max-tile: 84px;
    --tile-size: min(
      var(--desktop-board-max-tile),
      calc((100vw - var(--desktop-left-panel) - var(--desktop-right-panel) - var(--desktop-shell-pad) - var(--desktop-grid-gaps)) / 14)
    );
  }

  #app{
    max-width:none !important;
    width:100%;
    padding:10px 16px 12px !important;
    overflow:hidden;
  }

  .main-layout{
    display:grid !important;
    grid-template-columns: var(--desktop-left-panel) minmax(0, 1fr) var(--desktop-right-panel) !important;
    gap:12px !important;
    align-items:start !important;
    width:100% !important;
    max-width:100% !important;
    overflow:hidden !important;
  }

  .left-panel,
  .center-panel,
  .right-panel,
  #runLogPanel{
    min-width:0 !important;
    max-width:100% !important;
  }

  .runlog-inline-toggle{
    display:inline-flex;
  }

  .center-panel{
    grid-column:2 !important;
    width:100% !important;
    overflow:hidden !important;
    padding:8px !important;
  }

  .right-panel{
    grid-column:3 !important;
    width:100% !important;
    margin:0 !important;
    position:sticky !important;
    top:10px !important;
    align-self:start !important;
    max-height:calc(100dvh - 20px) !important;
    overflow-y:auto !important;
    overflow-x:hidden !important;
    transform:none !important;
    z-index:2 !important;
  }

  .grid,
  #grid{
    width:max-content !important;
    max-width:100% !important;
    margin:0 auto !important;
  }

  .center-panel .grid-wrap,
  .center-panel .grid,
  .center-panel #grid,
  .center-panel .enemy-layer{
    overflow:hidden !important;
    max-width:100% !important;
  }

  #runLogPanel{
    overflow:hidden !important;
  }

  body.runlog-collapsed{
    --desktop-left-panel: 46px;
  }

  body.runlog-collapsed #runLogPanel{
    padding-left:8px !important;
    padding-right:8px !important;
  }

  body.runlog-collapsed #runLogPanel .log,
  body.runlog-collapsed #runLogPanel .speed-toggle,
  body.runlog-collapsed #runLogPanel .mobile-toggle,
  body.runlog-collapsed #runLogPanel .pause-toggle,
  body.runlog-collapsed #runLogPanel .intro-toggle,
  body.runlog-collapsed #runLogPanel .meta-currency,
  body.runlog-collapsed #runLogPanel .wallet-panel,
  body.runlog-collapsed #runLogPanel .wallet-note,
  body.runlog-collapsed #runLogPanel .wallet-status,
  body.runlog-collapsed #runLogPanel .wallet-address,
  body.runlog-collapsed #runLogPanel .wallet-actions,
  body.runlog-collapsed #runLogPanel .wallet-bankline,
  body.runlog-collapsed #runLogPanel .profile-stats,
  body.runlog-collapsed #runLogPanel #leaderboardPanel{
    display:none !important;
  }

  body.runlog-collapsed #runLogPanel .runlog-header{
    justify-content:center;
    margin-bottom:0;
  }

  body.runlog-collapsed #runLogPanel .runlog-header h2{
    display:none !important;
  }
